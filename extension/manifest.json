{
  "manifest_version": 3,
  "name": "MILES Verify",
  "version": "1.0.0",
  "description": "Analyze selected text on social platforms with the MILES verification engine.",
  "action": {
    "default_title": "MILES Verify",
    "default_popup": "popup.html"
  },
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "permissions": [
    "storage",
    "tabs",
    "activeTab",
    "scripting"
  ],
  "host_permissions": [
    "http://localhost:3003/*",
    "https://*.facebook.com/*",
    "https://facebook.com/*",
    "https://*.x.com/*",
    "https://x.com/*",
    "https://*.twitter.com/*",
    "https://twitter.com/*",
    "https://*.instagram.com/*",
    "https://instagram.com/*",
    "https://*.linkedin.com/*",
    "https://linkedin.com/*",
    "https://*.reddit.com/*",
    "https://reddit.com/*",
    "https://*.youtube.com/*",
    "https://youtube.com/*",
    "https://threads.net/*",
    "https://*.threads.net/*",
    "https://*.tiktok.com/*",
    "https://tiktok.com/*"
  ],
  "content_scripts": [
    {
      "matches": [
        "https://*.facebook.com/*",
        "https://facebook.com/*",
        "https://*.x.com/*",
        "https://x.com/*",
        "https://*.twitter.com/*",
        "https://twitter.com/*",
        "https://*.instagram.com/*",
        "https://instagram.com/*",
        "https://*.linkedin.com/*",
        "https://linkedin.com/*",
        "https://*.reddit.com/*",
        "https://reddit.com/*",
        "https://*.youtube.com/*",
        "https://youtube.com/*",
        "https://threads.net/*",
        "https://*.threads.net/*",
        "https://*.tiktok.com/*",
        "https://tiktok.com/*"
      ],
      "js": ["contentScript.js"],
      "run_at": "document_idle"
    }
  ]
}
