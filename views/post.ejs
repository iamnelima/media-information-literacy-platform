    <script>
      window.onload = function () {
        //Max content for text area
        var textarea = document.getElementsByTagName("textarea")[0];
        var charCounter = document.getElementById("character-counter");
        textarea.setAttribute("maxlength", "1000");
        textarea.addEventListener("input", function () {
          let counter = textarea.value.length;
          if (counter >= 1000) {
            charCounter.innerText = "Max";
          } else {
            charCounter.innerText = counter;
          }
        });

        //Validating image upload
        var imageUpload = document.getElementById("image-upload");
        var userMessage = document.getElementById("user-message");
        var imageLabel = document.getElementById("image-label");
        userMessage.style.color = "red";
        var imageFile = null;
        imageUpload.addEventListener("change", function (e) {
          let files = e.target.files;
          let file = files[0];
          imageFile = file;
          let size = file.size;
          if (size > 10000000) {
            userMessage.innerText = "File must be 10MBs max";
          } else {
            const reader = new FileReader();
            imageLabel.style.opacity = 0.4;
            userMessage.innerText = "Click the image to change it";
            userMessage.style.color = "blue";
            reader.readAsDataURL(file);
            reader.onload = function (event) {
              let holder = document.getElementById("holder");
              holder.style.background = `url(${event.target.result})`;
            };
          }
        });

        // Post content, send to backend
        var postBtn = document.getElementById("post-btn");
        var errorMessage = document.getElementById("error-message");
        postBtn.addEventListener("click", function (e) {
          e.preventDefault();
          if (textarea.value.trim() == "") {
            errorMessage.innerText = "Please provide some text for context.";
            setTimeout(function () {
              errorMessage.innerText = "";
            }, 5000);
            return;
          } else {
            let uploadData = new FormData();
            uploadData.append("image", imageFile);
            uploadData.append("content", textarea.value);
            console.log(imageFile, textarea.value);
            fetch("/post", {
              method: "POST",
              body: uploadData,
            })
              .then((Response) => Response.json())
              .then((data) => {
                console.log(data.message);
                userMessage.textContent = data.message;
                userMessage.style.color = "red";
              });
          }
        });
      };
    </script>
