                      stroke-width="2"
                      stroke-linecap="round"
                      stroke-linejoin="round"
                      class="lucide lucide-trophy w-5 h-5 text-primary"
                    >
                      <path d="M6 9H4.5a2.5 2.5 0 0 1 0-5H6"></path>
                      <path d="M18 9h1.5a2.5 2.5 0 0 0 0-5H18"></path>
                      <path d="M4 22h16"></path>
                      <path
                        d="M10 14.66V17c0 .55-.47.98-.97 1.21C7.85 18.75 7 20.24 7 22"
                      ></path>
                      <path
                        d="M14 14.66V17c0 .55.47.98.97 1.21C16.15 18.75 17 20.24 17 22"
                      ></path>
                      <path d="M18 2H6v7a6 6 0 0 0 12 0V2Z"></path></svg
                    ><span>Activity Stats</span>
                  </h3>
                </div>
                <div class="p-6 pt-0">
                  <div class="grid grid-cols-2 gap-4">
                    <div class="text-center space-y-1">
                      <div class="flex items-center justify-center space-x-1">
                        <svg
                          xmlns="http://www.w3.org/2000/svg"
                          width="24"
                          height="24"
                          viewBox="0 0 24 24"
                          fill="none"
                          stroke="currentColor"
                          stroke-width="2"
                          stroke-linecap="round"
                          stroke-linejoin="round"
                          class="lucide lucide-message-circle w-4 h-4 text-primary"
                        >
                          <path d="M7.9 20A9 9 0 1 0 4 16.1L2 22Z"></path></svg
                        ><span class="text-2xl font-bold"
                          ><%=userInfo.reviews_given%></span
                        >
                      </div>
                      <p class="text-xs text-muted-foreground">Reviews Given</p>
                    </div>
                    <div class="text-center space-y-1">
                      <div class="flex items-center justify-center space-x-1">
                        <svg
                          xmlns="http://www.w3.org/2000/svg"
                          width="24"
                          height="24"
                          viewBox="0 0 24 24"
                          fill="none"
                          stroke="currentColor"
                          stroke-width="2"
                          stroke-linecap="round"
                          stroke-linejoin="round"
                          class="lucide lucide-star w-4 h-4 text-primary"
                        >
                          <path
                            d="M11.525 2.295a.53.53 0 0 1 .95 0l2.31 4.679a2.123 2.123 0 0 0 1.595 1.16l5.166.756a.53.53 0 0 1 .294.904l-3.736 3.638a2.123 2.123 0 0 0-.611 1.878l.882 5.14a.53.53 0 0 1-.771.56l-4.618-2.428a2.122 2.122 0 0 0-1.973 0L6.396 21.01a.53.53 0 0 1-.77-.56l.881-5.139a2.122 2.122 0 0 0-.611-1.879L2.16 9.795a.53.53 0 0 1 .294-.906l5.165-.755a2.122 2.122 0 0 0 1.597-1.16z"
                          ></path></svg
                        ><span class="text-2xl font-bold"
                          ><%=userInfo.no_of_posts%></span
                        >
                      </div>
                      <p class="text-xs text-muted-foreground">Posts</p>
                    </div>
                  </div>
                </div>
              </div>
            </div>
            <div
              class="rounded-lg border text-card-foreground shadow-sm bg-primary/5 border-primary/20"
            >
              <div id="guidelines" class="flex flex-col space-y-1.5 p-6">
                <h3 class="font-semibold tracking-tight text-lg text-primary">
                  GuideLines for Content:
                </h3>
              </div>
              <div class="p-6 pt-0 space-y-3">
                <div class="flex items-start space-x-3">
                  <div
                    class="w-6 h-6 bg-primary/20 rounded-full flex items-center justify-center flex-shrink-0 mt-0.5"
                  >
                    <span class="text-primary text-xs font-bold">1</span>
                  </div>
                  <p class="text-sm">
                    Inappropriate images will be declined and will not be
                    processed. Eg: Images containing nudity.
                  </p>
                </div>
                <div class="flex items-start space-x-3">
                  <div
                    class="w-6 h-6 bg-primary/20 rounded-full flex items-center justify-center flex-shrink-0 mt-0.5"
                  >
                    <span class="text-primary text-xs font-bold">2</span>
                  </div>
                  <p class="text-sm">
                    Content that enhances racism and any other forms of
                    deliberate discrimination will not be processed.
                  </p>
                </div>
                <div class="flex items-start space-x-3">
                  <div
                    class="w-6 h-6 bg-primary/20 rounded-full flex items-center justify-center flex-shrink-0 mt-0.5"
                  >
                    <span class="text-primary text-xs font-bold">3</span>
                  </div>
                  <p class="text-sm">
                    No Harmful Misinformation: Intentionally spreading false or
                    misleading content to manipulate others is prohibited.
                  </p>
                </div>
                <div class="flex items-start space-x-3">
                  <div
                    class="w-6 h-6 bg-primary/20 rounded-full flex items-center justify-center flex-shrink-0 mt-0.5"
                  >
                    <span class="text-primary text-xs font-bold">4</span>
                  </div>
                  <p class="text-sm">
                    Respectful Discussions: Critique the content, not the
                    person. No personal attacks, harassment, or hate speech.
                  </p>
                </div>
                <div class="flex items-start space-x-3">
                  <div
                    class="w-6 h-6 bg-primary/20 rounded-full flex items-center justify-center flex-shrink-0 mt-0.5"
                  >
                    <span class="text-primary text-xs font-bold">5</span>
                  </div>
                  <p class="text-sm">
                    No Spam: Refrain from flooding comments with irrelevant,
                    promotional, or repetitive material.
                  </p>
                </div>
                <div class="flex items-start space-x-3">
                  <div
                    class="w-6 h-6 bg-primary/20 rounded-full flex items-center justify-center flex-shrink-0 mt-0.5"
                  >
                    <span class="text-primary text-xs font-bold">6</span>
                  </div>
                  <p class="text-sm">
                    Violations of stated guidelines may result in temporary
                    banning and will affect Credibility Scores and Reputation
                    Points.
                  </p>
                </div>
                <div class="flex items-start space-x-3">
                  <div
                    class="w-6 h-6 bg-primary/20 rounded-full flex items-center justify-center flex-shrink-0 mt-0.5"
                  >
                    <span class="text-primary text-xs font-bold">7</span>
                  </div>
                  <p class="text-sm">
                    This is a safe space. Feel free share any content without
                    violating the said guidelines. We ought to remain credible.
                  </p>
                </div>
              </div>
            </div>
          </div>
        </main>
      </div>
    </div>
    <script>
      // Set email from session
      var emailHolder = document.getElementById("user-email");
      var sessionEmail = sessionStorage.getItem("user") || '';
      emailHolder.textContent = sessionEmail;

      var navEmailEl = document.getElementById('nav-user-email');
      if (navEmailEl) navEmailEl.textContent = sessionEmail;

      // Store profile picture in sessionStorage so other pages can use it
      <% if (userInfo.profile_picture) { %>
        sessionStorage.setItem('profile_picture', '<%= userInfo.profile_picture %>');
      <% } %>

      // Set credibility review
      var credReview = document.getElementById("cred-review");
      var credScore = parseInt(document.getElementById("cred-score").textContent);
      if (credScore >= 70) {
        credReview.textContent = "Highly Credible user";
      } else if (credScore >= 60) {
        credReview.textContent = "Credible user";
      }

      // Logout
      function milesLogout() {
        var sure = confirm("Are you sure you want to log out?");
        if (sure) {
          sessionStorage.clear();
          fetch("/profile", { method: "POST" }).then(function() {
            window.location.href = "/signin";
          });
        }
      }
      var logout = document.getElementById("logout");
      logout.addEventListener("click", milesLogout);

      // Avatar dropdown close on outside click
      document.addEventListener('click', function(e) {
        var dd  = document.getElementById('nav-avatar-dropdown');
        var btn = document.getElementById('nav-avatar-btn');
        if (dd && btn && !btn.contains(e.target) && !dd.contains(e.target)) {
          dd.classList.add('hidden');
        }
      });

      // Profile picture upload
      var picInput = document.getElementById('profile-pic-input');
      if (picInput) {
        picInput.addEventListener('change', function(e) {
          var file = e.target.files[0];
          if (!file) return;
          if (file.size > 5 * 1024 * 1024) {
            alert('Image must be under 5MB');
            return;
          }
          var statusEl = document.getElementById('pic-upload-status');
          statusEl.style.display = 'block';
          statusEl.textContent = 'Uploading...';

          var formData = new FormData();
          formData.append('profile_picture', file);

          fetch('/profile/picture', { method: 'POST', body: formData })
            .then(function(r) { return r.json(); })
            .then(function(data) {
              if (data.path) {
                // Update both profile pics on the page
                document.getElementById('profile-pic-large').src = '/' + data.path;
                var navImg = document.getElementById('nav-avatar-img');
                if (navImg) navImg.src = '/' + data.path;
                sessionStorage.setItem('profile_picture', data.path);
                statusEl.textContent = 'Updated!';
                setTimeout(function() { statusEl.style.display = 'none'; }, 2000);
              } else {
                statusEl.textContent = 'Failed';
                setTimeout(function() { statusEl.style.display = 'none'; }, 2000);
              }
            })
            .catch(function() {
              statusEl.textContent = 'Error';
              setTimeout(function() { statusEl.style.display = 'none'; }, 2000);
            });
        });
      }
    </script>
  </body>
</html>
