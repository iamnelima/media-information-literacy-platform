                <input type="text" name="q" placeholder="Search MILES..." class="flex h-9 w-full rounded-md border border-input bg-background pl-9 pr-3 py-1 text-sm shadow-sm transition-colors focus-visible:outline-none focus-visible:ring-1 focus-visible:ring-ring disabled:cursor-not-allowed disabled:opacity-50" value="<%= typeof searchQuery !== 'undefined' ? searchQuery : '' %>">
