                  ><svg
                    xmlns="http://www.w3.org/2000/svg"
                    width="24"
                    height="24"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="2"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    class="lucide lucide-message-circle w-5 h-5"
                  >
                    <path d="M7.9 20A9 9 0 1 0 4 16.1L2 22Z"></path></svg
                  ><span class="hidden lg:inline">AI Tutor</span></a
                >
                <a
                  class="flex items-center space-x-2 px-4 py-2 rounded-lg transition-all duration-200 text-muted-foreground hover:text-foreground hover:bg-muted"
                  href="/myposts"
