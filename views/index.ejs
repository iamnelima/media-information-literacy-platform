          </div>
          <!-- Mobile Sectors Sliding Menu -->
          <div id="mobile-sectors-menu" class="md:hidden hidden bg-card border-t border-border">
            <div class="grid grid-cols-2 gap-2 p-4">
              <a href="/sectors/politics" class="flex items-center space-x-2 p-3 rounded-lg hover:bg-muted text-sm border border-border/50 justify-center">Politics</a>
              <a href="/sectors/health" class="flex items-center space-x-2 p-3 rounded-lg hover:bg-muted text-sm border border-border/50 justify-center">Health</a>
              <a href="/sectors/tech" class="flex items-center space-x-2 p-3 rounded-lg hover:bg-muted text-sm border border-border/50 justify-center">Tech</a>
              <a href="/sectors/business" class="flex items-center space-x-2 p-3 rounded-lg hover:bg-muted text-sm border border-border/50 justify-center">Business</a>
