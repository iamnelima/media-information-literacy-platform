        <main class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
          <div class="space-y-6">
            <div class="text-center space-y-2">
              <h1 class="text-2xl font-bold"><%= typeof pageTitle !== 'undefined' ? pageTitle : 'Media Literacy Feed' %></h1>
              <p class="text-muted-foreground">
                Analyze content credibility and engage with verified information
              </p>
            </div>

            <!-- Feed Filters -->
            <div class="flex items-center gap-2 flex-wrap" style="margin-bottom:4px;">
              <button id="toggle-ai-btn" onclick="toggleAiFilter(this)" class="inline-flex items-center gap-1 text-xs font-medium px-3 py-1.5 rounded-full border border-border/60 bg-card hover:bg-muted transition-colors" style="cursor:pointer;">
                🤖 <span id="ai-btn-label">Hide AI-Generated</span>
              </button>
            </div>

            <!-- Inline Posting Form -->
            <div
              class="inline-posting-form-container rounded-lg border bg-card text-card-foreground shadow-sm border-border/50 mb-8"
            >
              <div class="p-6">
                <form class="space-y-4">
                  <div class="space-y-2">
                    <p
                      id="error-message"
                      class="text-sm font-medium text-destructive"
                      style="color: red"
                    ></p>
                    <textarea
                      class="flex min-h-[80px] w-full rounded-md border border-input bg-background px-3 py-2 text-sm ring-offset-background placeholder:text-muted-foreground focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring focus-visible:ring-offset-2 disabled:cursor-not-allowed disabled:opacity-50 resize-none"
                      id="content"
                      placeholder="Share a news article, claim, or information you'd like analyzed..."
                      rows="3"
                    ></textarea>
                    <p class="text-xs text-muted-foreground flex justify-between">
                      <span id="user-message"></span>
                      <span><span id="character-counter">0</span>/1000 characters</span>
                    </p>
                  </div>
                  
                  <div class="flex items-center justify-between">
                    <div class="flex items-center space-x-2">
                      <label id="image-label" for="image-upload" class="cursor-pointer inline-flex items-center justify-center rounded-md text-sm font-medium transition-colors focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring focus-visible:ring-offset-2 disabled:opacity-50 disabled:pointer-events-none ring-offset-background hover:bg-accent hover:text-accent-foreground h-9 py-2 px-3">
                        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-image w-4 h-4 mr-2"><rect width="18" height="18" x="3" y="3" rx="2" ry="2"></rect><circle cx="9" cy="9" r="2"></circle><path d="m21 15-3.086-3.086a2 2 0 0 0-2.828 0L6 21"></path></svg>
                        Add Image
                      </label>
                      <input type="file" class="hidden" accept="image/*" id="image-upload" />
                      <div id="holder" class="w-8 h-8 rounded-md bg-muted bg-cover bg-center hidden"></div>
                      <input type="hidden" id="current-sector" value="<%= typeof currentSector !== 'undefined' && currentSector ? currentSector : '' %>" />
                    </div>
                    
                    <button
                      id="post-btn"
                      class="inline-flex items-center justify-center rounded-md text-sm font-medium transition-colors focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring focus-visible:ring-offset-2 disabled:opacity-50 disabled:pointer-events-none ring-offset-background bg-primary text-primary-foreground hover:bg-primary/90 h-9 px-4 py-2"
                      type="submit"
                    >
                      Post for Analysis
                    </button>
                  </div>
                </form>
              </div>
            </div>
            <div class="max-w-2xl mx-auto">
              <% posts.forEach((post)=> { %>
              <div
                id="<%=post.post_id%>"
                class="post-card rounded-lg border bg-card text-card-foreground mb-6 shadow-sm hover:shadow-md transition-shadow duration-200 border-border/50"
                data-ai="<%- post.is_ai_generated ? 'true' : 'false' %>"
                style="cursor:pointer;"
                onclick="window.location.href='/posts/<%=post.post_id%>'"
              >
                <div class="flex flex-col space-y-1.5 p-6 pb-3">
                  <div class="flex items-start justify-between">
                    <div class="flex items-center space-x-3">
                      <span
                        class="relative flex shrink-0 overflow-hidden rounded-full w-10 h-10"
                        ><span
                          class="flex h-full w-full items-center justify-center rounded-full bg-primary/10 text-primary"
                        >
                          <%= post.author[0] %></span
                        ></span
                      >
                      <div>
                        <h3 class="font-semibold text-sm">
                          <%= post.author %>
                        </h3>
                      </div>
                    </div>
                  </div>
                </div>

                <div class="p-6 pt-0 space-y-4">
                  <div class="space-y-3">
                    <%if(post.image_location){%>
                    <div
                      class="aspect-product overflow-hidden rounded-t-xl bg-muted/30"
                    >
                      <img
                        src="/<%=post.image_location%>"
                        alt="Wimask Accesories Phones"
                        loading="lazy"
                        style="border-radius: 5px"
                        class="product-image h-full w-full object-cover transition-transform duration-300 group-hover:scale-105"
                        sizes="(max-width: 768px) 100vw, (max-width: 1200px) 50vw, 33vw"
                      />
                    </div>
                    <%}%>

                    <p class="text-foreground leading-relaxed">
                      <%=post.text_content%>
                    </p>
                    <% if(post.sector) { %>
                      <div class="mt-2 text-xs text-muted-foreground bg-muted/30 px-2 py-1 rounded inline-block">
                        Sector: <strong><%= post.sector %></strong>
                      </div>
                    <% } %>
                    <% if(post.claim_count && post.claim_count > 1) { %>
                      <div class="mt-2 ml-1 text-xs px-2 py-1 rounded inline-block font-semibold" style="background:#fff3cd; color:#856404; border:1px solid #ffc107;">
                        📢 This claim has appeared <strong><%= post.claim_count %></strong> time<%= post.claim_count === 1 ? '' : 's' %> on MILES
                      </div>
                    <% } %>
                    <% if(post.created_at) { %>
                      <div class="mt-1 text-xs text-muted-foreground" style="opacity:0.6;">
                        Posted: <%= new Date(post.created_at).toLocaleDateString('en-US', {year:'numeric',month:'short',day:'numeric',hour:'2-digit',minute:'2-digit'}) %>
                      </div>
                    <% } %>
                    <% if(post.is_ai_generated) { %>
                      <div class="ai-generated-badge mt-2 inline-flex items-center gap-1 text-xs font-semibold px-2 py-1 rounded-full" style="background:rgba(139,92,246,0.12);color:#7c3aed;border:1px solid rgba(139,92,246,0.3);">
                        🤖 AI-Generated Content
                      </div>
                    <% } %>
                  </div>
                  <hr />
                  <div class="bg-muted/30 rounded-lg p-4 space-y-3 ai-analysis">
                    <div class="flex items-center justify-between">
                      <div class="flex items-center space-x-3">
                        <div class="flex items-center space-x-2">
                          <!-- Credibility Score Bar -->
                          <div class="credibility-bar-wrap" style="min-width:140px;">
                            <div style="display:flex;align-items:center;gap:6px;margin-bottom:3px;">
                              <span class="text-sm font-bold" style="color:<%=post.verdict_color||'#6b7280'%>;"><%=post.credibility_score%>%</span>
                              <span class="text-xs text-muted-foreground">credible</span>
                            </div>
                            <div style="width:140px;height:7px;border-radius:999px;background:#e5e7eb;overflow:hidden;">
                              <div style="height:100%;width:<%=post.credibility_score%>%;background:<%=post.verdict_color||'#6b7280'%>;border-radius:999px;transition:width 0.6s ease;"></div>
                            </div>
                            <div style="font-size:10px;color:#9ca3af;margin-top:3px;">
                              <% if(post.verification && post.verification.score_breakdown) { %>
                                <%= post.verification.score_breakdown %>
                              <% } else { %>
                                <% var unverified = 100 - (post.credibility_score||0); %>
                                <% if(unverified > 0) { %>
                                  <%=unverified%>% of this content has weak or unverified claims
                                <% } else { %>
                                  Fully supported by evidence
                                <% } %>
                              <% } %>
                            </div>
                          </div>
                        </div>
                        <div
                          class="inline-flex items-center rounded-full border px-2.5 py-0.5 text-xs transition-colors focus:outline-none focus:ring-2 focus:ring-ring focus:ring-offset-2 border-transparent hover:bg-primary/80 bg-credible-high text-white font-medium"
                          style="background: <%= post.verdict_color || '#6b7280' %>"
                        >
                          <%= post.verdict_label %>
                        </div>
                      </div>
                      <button
                        onclick="event.stopPropagation()"
                        class="details inline-flex items-center justify-center gap-2 whitespace-nowrap font-medium ring-offset-background transition-colors focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring focus-visible:ring-offset-2 disabled:pointer-events-none disabled:opacity-50 hover:bg-accent hover:text-accent-foreground h-9 rounded-md px-3 text-xs"
                      >
                        Details
                        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-chevron-down w-3 h-3 ml-1"><path d="m6 9 6 6 6-6"></path></svg>
                      </button>
                    </div>
                    <p class="text-sm text-muted-foreground">
                      <span class="font-medium text-foreground"
                        >AI Analysis:</span
                      >
                      <%=post.ai_analysis%>
                    </p>
                    <% if (post.verification) { %>
                    <div class="verification-block">
                      <% if (post.verification.verification_methodology) { %>
                      <p class="verification-meta">
                        <span class="font-medium text-foreground">Method:</span>
                        <%= post.verification.verification_methodology %>
                      </p>
                      <% } %>
                      <% if (post.verification.key_claims && post.verification.key_claims.length > 0) { %>
                      <div class="verification-section">
                        <p class="verification-title">Key Claims</p>
                        <% post.verification.key_claims.forEach((claim) => { %>
                        <div class="verification-item">
                          <p class="verification-claim"><%= claim.claim %></p>
                          <p class="verification-meta">
                            <strong><%= claim.assessment %></strong>
                            <% if (claim.confidence) { %>
                            | <%= claim.confidence %> confidence
                            <% } %>
                          </p>
                          <% if (claim.rationale) { %>
                          <p class="verification-meta"><%= claim.rationale %></p>
                          <% } %>
                        </div>
                        <% }) %>
                      </div>
                      <% } %>
                      <% if (post.verification.supporting_evidence && post.verification.supporting_evidence.length > 0) { %>
                      <div class="verification-section">
                        <p class="verification-title">Supporting Evidence</p>
                        <% post.verification.supporting_evidence.forEach((item) => { %>
                        <p class="verification-item"><%= item %></p>
                        <% }) %>
                      </div>
                      <% } %>
                      <% if (post.verification.contradicting_evidence && post.verification.contradicting_evidence.length > 0) { %>
                      <div class="verification-section">
                        <p class="verification-title">Contradicting Evidence</p>
                        <% post.verification.contradicting_evidence.forEach((item) => { %>
                        <p class="verification-item"><%= item %></p>
                        <% }) %>
                      </div>
                      <% } %>
                      <% if (post.verification.sources && post.verification.sources.length > 0) { %>
                      <div class="verification-section">
                        <p class="verification-title">Evidence Sources</p>
                        <div class="source-list">
                          <% post.verification.sources.forEach((source) => { %>
                          <a
                            class="source-chip"
                            href="<%= source.url %>"
                            target="_blank"
                            rel="noreferrer"
                          >
                            <span><%= source.title %></span>
                            <% if (source.domain) { %>
                            <small><%= source.domain %></small>
                            <% } %>
                          </a>
                          <% }) %>
                        </div>
                      </div>
                      <% } %>
                      <% if (post.verification.recommended_checks && post.verification.recommended_checks.length > 0) { %>
                      <div class="verification-section">
                        <p class="verification-title">Next Checks</p>
                        <% post.verification.recommended_checks.forEach((item) => { %>
                        <p class="verification-item"><%= item %></p>
                        <% }) %>
                      </div>
                      <% } %>
                    </div>
                    <% } %>
                  </div>
                  <div class="flex items-center justify-between pt-2">
                    <div class="flex items-center space-x-6">
                      <button
                        onclick="event.stopPropagation(); window.location.href='/posts/<%=post.post_id%>'"
                        class="reviews justify-center gap-2 whitespace-nowrap text-sm font-medium ring-offset-background transition-colors focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring focus-visible:ring-offset-2 disabled:pointer-events-none disabled:opacity-50 hover:bg-accent h-9 rounded-md px-3 flex items-center space-x-2 text-muted-foreground hover:text-primary"
                      >
                        <svg
                          xmlns="http://www.w3.org/2000/svg"
                          width="24"
                          height="24"
                          viewBox="0 0 24 24"
                          fill="none"
                          stroke="currentColor"
                          stroke-width="2"
                          stroke-linecap="round"
                          stroke-linejoin="round"
                          class="lucide lucide-message-circle w-4 h-4"
                          style="scale: 1.5"
                        >
                          <path d="M7.9 20A9 9 0 1 0 4 16.1L2 22Z"></path></svg
                        ><span id="review-badge-<%=post.post_id%>" class="text-l"><%= post.comments ? post.comments.length : 0 %></span>
                      </button>
                    </div>
                  </div>
                </div>
              </div>
              <% }) %>
            </div>
          </div>
        </main>
      </div>


      <!-- Post Processing Modal -->
      <div style="display: none" class="modal-overlay">
        <div
          class="modal-content rounded-lg border text-card-foreground shadow-sm bg-primary/5 border-primary/20"
        >
          <div class="flex flex-col space-y-1.5 p-6">
            <h3
              id="waiting"
              style="text-align: center"
              class="font-semibold tracking-tight text-lg text-primary"
            >
              Processing.
            </h3>
          </div>
        </div>
      </div>
    </div>
    <script>
      // ── AI filter toggle ──────────────────────────────────────
      var aiFilterActive = false;
      function toggleAiFilter(btn) {
        aiFilterActive = !aiFilterActive;
        document.getElementById('ai-btn-label').textContent = aiFilterActive ? 'Show AI-Generated' : 'Hide AI-Generated';
        btn.style.background  = aiFilterActive ? 'rgba(139,92,246,0.12)' : '';
        btn.style.color       = aiFilterActive ? '#7c3aed' : '';
        btn.style.borderColor = aiFilterActive ? 'rgba(139,92,246,0.4)' : '';
        document.querySelectorAll('.post-card[data-ai="true"]').forEach(function(c){ c.style.display = aiFilterActive ? 'none' : ''; });
      }

      // ── Dynamic nav active state ──────────────────────────────
      (function() {
        var path = window.location.pathname;
        document.querySelectorAll('nav a[href]').forEach(function(a) {
          var href = a.getAttribute('href');
          if (!href || href === '#') return;
          var active = (href === '/' && path === '/') || (href !== '/' && path.startsWith(href));
          if (active) { a.style.cssText += ';background:rgba(124,58,237,0.1);color:rgb(124,58,237);font-weight:600;'; }
        });
      })();

      // ── Close sectors dropdown on outside click ───────────────
      document.addEventListener('click', function(e) {
        var dd  = document.getElementById('sectors-dropdown');
        var btn = document.getElementById('sectors-menu-btn');
        if (dd && btn && !btn.contains(e.target) && !dd.contains(e.target)) { dd.classList.add('hidden'); }
      });

      window.onload = function () {
        // ── Details expand/collapse ───────────────────────────
        var analysisBoxes = Array.from(document.getElementsByClassName('ai-analysis'));
        Array.from(document.getElementsByClassName('details')).forEach(function(btn, i) {
          btn.addEventListener('click', function(e) {
            e.stopPropagation();
            var box = analysisBoxes[i];
            if (!btn.classList.contains('show')) {
              btn.classList.add('show');
              box.style.height = 'fit-content';
            } else {
              btn.classList.remove('show');
              box.style.height = '125px';
            }
          });
        });

        // ── Comment verify buttons (pre-existing on load) ─────
        document.querySelectorAll('.verify-comment-btn').forEach(function(btn) {
          btn.addEventListener('click', function(e) {
            e.stopPropagation();
            var text   = decodeURIComponent(this.getAttribute('data-comment'));
            var result = this.nextElementSibling;
            var self   = this;
            self.textContent = 'Verifying\u2026';
            self.disabled = true;
            fetch('/verify-comment', {method:'POST', headers:{'Content-Type':'application/json'}, body:JSON.stringify({comment:text})})
              .then(function(r){ return r.json(); })
              .then(function(d) {
                self.textContent = 'Verified';
                result.classList.remove('hidden');
                result.innerHTML = '<span style="color:'+d.verdict_color+';font-weight:bold;">['+d.verdict_label+']</span> '+d.explanation;
              })
              .catch(function(){ self.textContent = 'Verify Credibility'; self.disabled = false; });
          });
        });

        // ── Inline post form ──────────────────────────────────
        var textarea     = document.getElementById('content');
        var charCounter  = document.getElementById('character-counter');
        var imageUpload  = document.getElementById('image-upload');
        var userMessage  = document.getElementById('user-message');
        var imageLabel   = document.getElementById('image-label');
        var holder       = document.getElementById('holder');
        var postBtn      = document.getElementById('post-btn');
        var errorMessage = document.getElementById('error-message');
        var sectorInput  = document.getElementById('current-sector');
        var imageFile    = null;

        if (textarea) {
          textarea.setAttribute('maxlength','1000');
          textarea.addEventListener('input', function() {
            charCounter.innerText = textarea.value.length >= 1000 ? 'Max' : textarea.value.length;
          });
        }

        if (imageUpload) {
          imageUpload.addEventListener('change', function(e) {
            var file = e.target.files[0];
            if (!file) return;
            imageFile = file;
            if (file.size > 10000000) {
              userMessage.style.color = 'red';
              userMessage.innerText = 'File must be 10MB max';
              return;
            }
            var reader = new FileReader();
            imageLabel.innerHTML = '<span class="text-xs text-primary">Image Selected</span>';
            userMessage.innerText = '';
            reader.readAsDataURL(file);
            reader.onload = function(ev) {
              holder.style.display = 'block';
              holder.style.backgroundImage = 'url(' + ev.target.result + ')';
            };
          });
        }

        if (postBtn) {
          postBtn.addEventListener('click', function(e) {
            e.preventDefault();
            if (!textarea || textarea.value.trim() === '') {
              errorMessage.innerText = 'Please provide some text.';
              setTimeout(function(){ errorMessage.innerText = ''; }, 5000);
              return;
            }
            var uploadData = new FormData();
            uploadData.append('image', imageFile);
            uploadData.append('content', textarea.value);
            if (sectorInput && sectorInput.value.trim()) uploadData.append('sector', sectorInput.value);

            var modalHolder = document.getElementsByClassName('modal-overlay')[0];
            var modal = document.getElementById('waiting');
            modalHolder.style.display = 'flex';
            var msgs  = ['Please wait while we process the content.', 'AI analyzing content.'];
            var mi    = 0;
            var ticker = setInterval(function(){ modal.textContent = msgs[mi]; mi = (mi+1)%2; }, 3000);

            fetch('/post', {method:'POST', body: uploadData})
              .then(function(r){ return r.json(); })
              .then(function(data) {
                clearInterval(ticker);
                if (data.color === 'red' || data.color === 'orange') {
                  userMessage.textContent = data.message;
                  userMessage.style.color = 'red';
                  modalHolder.style.display = 'none';
                } else {
                  modal.textContent = 'Successfully uploaded content.';
                  window.location.reload();
                }
              })
              .catch(function(){ clearInterval(ticker); modalHolder.style.display='none'; alert('Upload failed, please try again.'); });
          });
        }

        // (Removed duplicate JS toggles, inline onclick handles sectormenu natively to prevent double-toggle bug)

        // ── "Post" link smooth-scrolls to form ───────────────
        document.querySelectorAll('a[href="/post"]').forEach(function(link) {
          link.addEventListener('click', function(e) {
            var form = document.querySelector('.inline-posting-form-container');
            if (form) {
              e.preventDefault();
              form.scrollIntoView({behavior:'smooth', block:'center'});
              if (textarea) textarea.focus();
            }
          });
        });
      };

      // ── Avatar dropdown: close on outside click ───────────────
      document.addEventListener('click', function(e) {
        var dd  = document.getElementById('nav-avatar-dropdown');
        var btn = document.getElementById('nav-avatar-btn');
        if (dd && btn && !btn.contains(e.target) && !dd.contains(e.target)) {
          dd.classList.add('hidden');
        }
      });

      // ── Load avatar + email from session ─────────────────────
      (function() {
        var email = sessionStorage.getItem('user') || '';
        var emailEl = document.getElementById('nav-user-email');
        if (emailEl && email) emailEl.textContent = email;

        var savedPic = sessionStorage.getItem('profile_picture');
        var avatarImg = document.getElementById('nav-avatar-img');
        if (avatarImg && savedPic) avatarImg.src = '/' + savedPic;
      })();

      // ── Logout function ──────────────────────────────────────
      function milesLogout() {
        var sure = confirm('Are you sure you want to log out?');
        if (sure) {
          sessionStorage.clear();
          fetch('/profile', { method: 'POST' }).then(function() {
            window.location.href = '/signin';
          });
        }
      }
    </script>
  </body>
</html>
