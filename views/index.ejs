        <main class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
          <div class="space-y-6">
            <div class="text-center space-y-2">
              <h1 class="text-2xl font-bold"><%= typeof pageTitle !== 'undefined' ? pageTitle : 'Media Literacy Feed' %></h1>
              <p class="text-muted-foreground">
                Analyze content credibility and engage with verified information
              </p>
            </div>

            <!-- Inline Posting Form -->
            <div
              class="inline-posting-form-container rounded-lg border bg-card text-card-foreground shadow-sm border-border/50 mb-8"
            >
              <div class="p-6">
                <form class="space-y-4">
                  <div class="space-y-2">
                    <p
                      id="error-message"
                      class="text-sm font-medium text-destructive"
                      style="color: red"
                    ></p>
                    <textarea
                      class="flex min-h-[80px] w-full rounded-md border border-input bg-background px-3 py-2 text-sm ring-offset-background placeholder:text-muted-foreground focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring focus-visible:ring-offset-2 disabled:cursor-not-allowed disabled:opacity-50 resize-none"
                      id="content"
                      placeholder="Share a news article, claim, or information you'd like analyzed..."
                      rows="3"
                    ></textarea>
                    <p class="text-xs text-muted-foreground flex justify-between">
                      <span id="user-message"></span>
                      <span><span id="character-counter">0</span>/1000 characters</span>
                    </p>
                  </div>
                  
                  <div class="flex items-center justify-between">
                    <div class="flex items-center space-x-2">
                      <label id="image-label" for="image-upload" class="cursor-pointer inline-flex items-center justify-center rounded-md text-sm font-medium transition-colors focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring focus-visible:ring-offset-2 disabled:opacity-50 disabled:pointer-events-none ring-offset-background hover:bg-accent hover:text-accent-foreground h-9 py-2 px-3">
                        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-image w-4 h-4 mr-2"><rect width="18" height="18" x="3" y="3" rx="2" ry="2"></rect><circle cx="9" cy="9" r="2"></circle><path d="m21 15-3.086-3.086a2 2 0 0 0-2.828 0L6 21"></path></svg>
                        Add Image
                      </label>
                      <input type="file" class="hidden" accept="image/*" id="image-upload" />
                      <div id="holder" class="w-8 h-8 rounded-md bg-muted bg-cover bg-center hidden"></div>
                      <input type="hidden" id="current-sector" value="<%= typeof currentSector !== 'undefined' && currentSector ? currentSector : '' %>" />
                    </div>
                    
                    <button
                      id="post-btn"
                      class="inline-flex items-center justify-center rounded-md text-sm font-medium transition-colors focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring focus-visible:ring-offset-2 disabled:opacity-50 disabled:pointer-events-none ring-offset-background bg-primary text-primary-foreground hover:bg-primary/90 h-9 px-4 py-2"
                      type="submit"
                    >
                      Post for Analysis
                    </button>
                  </div>
                </form>
              </div>
            </div>
            <div class="max-w-2xl mx-auto">
              <% posts.forEach((post)=>{ %>
              <div
                id="<%=post.post_id%>"
                class="rounded-lg border bg-card text-card-foreground mb-6 shadow-sm hover:shadow-md transition-shadow duration-200 border-border/50"
              >
                <div class="flex flex-col space-y-1.5 p-6 pb-3">
                  <div class="flex items-start justify-between">
                    <div class="flex items-center space-x-3">
                      <span
                        class="relative flex shrink-0 overflow-hidden rounded-full w-10 h-10"
                        ><span
                          class="flex h-full w-full items-center justify-center rounded-full bg-primary/10 text-primary"
                        >
                          <%= post.author[0] %></span
                        ></span
                      >
                      <div>
                        <h3 class="font-semibold text-sm">
                          <%= post.author %>
                        </h3>
                      </div>
                    </div>
                  </div>
                </div>

                <div class="p-6 pt-0 space-y-4">
                  <div class="space-y-3">
                    <%if(post.image_location){%>
                    <div
                      class="aspect-product overflow-hidden rounded-t-xl bg-muted/30"
                    >
                      <img
                        src="/<%=post.image_location%>"
                        alt="Wimask Accesories Phones"
                        loading="lazy"
                        style="border-radius: 5px"
                        class="product-image h-full w-full object-cover transition-transform duration-300 group-hover:scale-105"
                        sizes="(max-width: 768px) 100vw, (max-width: 1200px) 50vw, 33vw"
                      />
                    </div>
                    <%}%>

                    <p class="text-foreground leading-relaxed">
                      <%=post.text_content%>
                    </p>
                    <% if(post.sector) { %>
                      <div class="mt-2 text-xs text-muted-foreground bg-muted/30 px-2 py-1 rounded inline-block">
                        Sector: <strong><%= post.sector %></strong>
                      </div>
                    <% } %>
                    <% if(post.claim_count && post.claim_count > 1) { %>
                      <div class="mt-2 ml-1 text-xs px-2 py-1 rounded inline-block font-semibold" style="background:#fff3cd; color:#856404; border:1px solid #ffc107;">
                        📢 This claim has appeared <strong><%= post.claim_count %></strong> time<%= post.claim_count === 1 ? '' : 's' %> on MILES
                      </div>
                    <% } %>
                    <% if(post.created_at) { %>
                      <div class="mt-1 text-xs text-muted-foreground" style="opacity:0.6;">
                        Posted: <%= new Date(post.created_at).toLocaleDateString('en-US', {year:'numeric',month:'short',day:'numeric',hour:'2-digit',minute:'2-digit'}) %>
                      </div>
                    <% } %>
                  </div>
                  <hr />
                  <div class="bg-muted/30 rounded-lg p-4 space-y-3 ai-analysis">
                    <div class="flex items-center justify-between">
                      <div class="flex items-center space-x-3">
                        <div class="flex items-center space-x-2">
                          <span class="text-sm font-medium"
                            ><%=post.credibility_score%>%</span
                          >
                        </div>
                        <div
                          class="inline-flex items-center rounded-full border px-2.5 py-0.5 text-xs transition-colors focus:outline-none focus:ring-2 focus:ring-ring focus:ring-offset-2 border-transparent hover:bg-primary/80 bg-credible-high text-white font-medium"
                          style="background: <%= post.verdict_color || '#6b7280' %>"
                        >
                          <%= post.verdict_label %>
                        </div>
                      </div>
                      <button
                        class="details inline-flex items-center justify-center gap-2 whitespace-nowrap font-medium ring-offset-background transition-colors focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring focus-visible:ring-offset-2 disabled:pointer-events-none disabled:opacity-50 [&amp;_svg]:pointer-events-none [&amp;_svg]:size-4 [&amp;_svg]:shrink-0 hover:bg-accent hover:text-accent-foreground h-9 rounded-md px-3 text-xs"
                      >
                        Details
                        <svg
                          xmlns="http://www.w3.org/2000/svg"
                          width="24"
                          height="24"
                          viewBox="0 0 24 24"
                          fill="none"
                          stroke="currentColor"
                          stroke-width="2"
                          stroke-linecap="round"
                          stroke-linejoin="round"
                          class="lucide lucide-chevron-down w-3 h-3 ml-1"
                        >
                          <path d="m6 9 6 6 6-6"></path>
                        </svg>
                      </button>
                    </div>
                    <p class="text-sm text-muted-foreground">
                      <span class="font-medium text-foreground"
                        >AI Analysis:</span
                      >
                      <%=post.ai_analysis%>
                    </p>
                  </div>
                  <div class="flex items-center justify-between pt-2">
                    <div class="flex items-center space-x-6">
                      <button
                        class="reviews justify-center gap-2 whitespace-nowrap text-sm font-medium ring-offset-background transition-colors focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring focus-visible:ring-offset-2 disabled:pointer-events-none disabled:opacity-50 [&amp;_svg]:pointer-events-none [&amp;_svg]:size-4 [&amp;_svg]:shrink-0 hover:bg-accent h-9 rounded-md px-3 flex items-center space-x-2 text-muted-foreground hover:text-primary"
                      >
                        <svg
                          xmlns="http://www.w3.org/2000/svg"
                          width="24"
                          height="24"
                          viewBox="0 0 24 24"
                          fill="none"
                          stroke="currentColor"
                          stroke-width="2"
                          stroke-linecap="round"
                          stroke-linejoin="round"
                          class="lucide lucide-message-circle w-4 h-4"
                          style="scale: 1.5"
                        >
                          <path d="M7.9 20A9 9 0 1 0 4 16.1L2 22Z"></path></svg
                        ><span class="text-l">8</span>
                      </button>
                    </div>
                  </div>
                </div>
              </div>
              <div
                data-state="open"
                class="comments-holder fixed inset-0 z-50 bg-black/80 data-[state=open]:animate-in data-[state=closed]:animate-out data-[state=closed]:fade-out-0 data-[state=open]:fade-in-0"
                data-aria-hidden="true"
                style="pointer-events: auto; display: none"
              >
                <div
                  role="dialog"
                  id="radix-:r0:"
                  aria-describedby="radix-:r2:"
                  aria-labelledby="radix-:r1:"
                  data-state="open"
                  class="fixed left-[50%] top-[50%] z-50 grid w-full translate-x-[-50%] translate-y-[-50%] gap-4 border bg-background p-6 shadow-lg duration-200 data-[state=open]:animate-in data-[state=closed]:animate-out data-[state=closed]:fade-out-0 data-[state=open]:fade-in-0 data-[state=closed]:zoom-out-95 data-[state=open]:zoom-in-95 data-[state=closed]:slide-out-to-left-1/2 data-[state=closed]:slide-out-to-top-[48%] data-[state=open]:slide-in-from-left-1/2 data-[state=open]:slide-in-from-top-[48%] sm:rounded-lg max-w-2xl max-h-[80vh] overflow-y-auto"
                  tabindex="-1"
                  style="pointer-events: auto"
                >
                  <div
                    class="flex flex-col space-y-1.5 text-center sm:text-left"
                  >
                    <h2
                      id="radix-:r1:"
                      class="text-lg font-semibold leading-none tracking-tight"
                    >
                      Community Reviews &amp; Comments
                    </h2>
                  </div>
                  <div class="space-y-4">
                    <div class="space-y-4">
                      <% if(post.comments.length > 0){ %>
                      <%(post.comments).forEach((comment)=>{%>

                      <div class="flex space-x-3 p-3 rounded-lg bg-muted/30">
                        <span
                          class="relative flex shrink-0 overflow-hidden rounded-full w-8 h-8"
                          ><span
                            class="flex h-full w-full items-center justify-center rounded-full bg-primary/10 text-primary text-xs"
                          >
                            <%= comment.commenter[0].toUpperCase() %>
                          </span></span
                        >
                        <div class="flex-1">
                          <div class="flex items-center space-x-2 mb-1">
                            <span class="font-medium text-sm"
                              ><%= comment.commenter%></span
                            >
                          </div>
                          <p class="text-sm text-foreground">
                            <%= comment.review %>
                          </p>
                        </div>
                      </div>

                      <%});} else{%>

                      <p class="text-sm text-foreground">
                        No comments yet, be first to comment.
                      </p>

                      <%}%>
                    </div>
                    <div class="flex space-x-3 pt-4 border-t border-border">
                      <span
                        class="relative flex shrink-0 overflow-hidden rounded-full w-8 h-8"
                        ><span
                          class="user-label flex h-full w-full items-center justify-center rounded-full bg-primary/10 text-primary text-xs"
                        ></span
                      ></span>
                      <div class="flex-1 flex space-x-2">
                        <input
                          type="text"
                          class="flex h-10 w-full rounded-md border border-input bg-background px-3 py-2 text-base ring-offset-background file:border-0 file:bg-transparent file:text-sm file:font-medium file:text-foreground placeholder:text-muted-foreground focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring focus-visible:ring-offset-2 disabled:cursor-not-allowed disabled:opacity-50 md:text-sm"
                          placeholder="Add your review or observation..."
                          value=""
                        /><button
                          id="<%=post.post_id%>"
                          class="send-btn inline-flex items-center justify-center gap-2 whitespace-nowrap text-sm font-medium ring-offset-background transition-colors focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring focus-visible:ring-offset-2 disabled:pointer-events-none disabled:opacity-50 [&amp;_svg]:pointer-events-none [&amp;_svg]:size-4 [&amp;_svg]:shrink-0 bg-primary text-primary-foreground hover:bg-primary/90 h-9 rounded-md px-3"
                        >
                          <svg
                            xmlns="http://www.w3.org/2000/svg"
                            width="24"
                            height="24"
                            viewBox="0 0 24 24"
                            fill="none"
                            stroke="currentColor"
                            stroke-width="2"
                            stroke-linecap="round"
                            stroke-linejoin="round"
                            class="lucide lucide-send w-4 h-4"
                          >
                            <path
                              d="M14.536 21.686a.5.5 0 0 0 .937-.024l6.5-19a.496.496 0 0 0-.635-.635l-19 6.5a.5.5 0 0 0-.024.937l7.93 3.18a2 2 0 0 1 1.112 1.11z"
                            ></path>
                            <path d="m21.854 2.147-10.94 10.939"></path>
                          </svg>
                        </button>
                      </div>
                    </div>
                  </div>
                  <button
                    type="button"
                    class="close-btn absolute right-4 top-4 rounded-sm opacity-70 ring-offset-background transition-opacity data-[state=open]:bg-accent data-[state=open]:text-muted-foreground hover:opacity-100 focus:outline-none focus:ring-2 focus:ring-ring focus:ring-offset-2 disabled:pointer-events-none"
                  >
                    <svg
                      xmlns="http://www.w3.org/2000/svg"
                      width="24"
                      height="24"
                      viewBox="0 0 24 24"
                      fill="none"
                      stroke="currentColor"
                      stroke-width="2"
                      stroke-linecap="round"
                      stroke-linejoin="round"
                      class="lucide lucide-x h-4 w-4"
                    >
                      <path d="M18 6 6 18"></path>
                      <path d="m6 6 12 12"></path></svg
                    ><span class="sr-only">Close</span>
                  </button>
                </div>
              </div>
              <%}) %>
            </div>
          </div>
        </main>
      </div>

      <!-- Post Processing Modal -->
      <div style="display: none" class="modal-overlay">
        <div
          class="modal-content rounded-lg border text-card-foreground shadow-sm bg-primary/5 border-primary/20"
        >
          <div class="flex flex-col space-y-1.5 p-6">
            <h3
              id="waiting"
              style="text-align: center"
              class="font-semibold tracking-tight text-lg text-primary"
            >
              Processing.
            </h3>
          </div>
        </div>
      </div>
    </div>
    <script>
      window.onload = function () {
        //user label for comments
        var labelArr = Array.from(
          document.getElementsByClassName("user-label")
        );

        var currentUser = sessionStorage.getItem("user");
        if (currentUser) {
          labelArr.forEach((label) => {
            label.textContent = currentUser[0].toUpperCase();
          });
        }

        //Details dropdown
        var analysisBoxArr = Array.from(
          document.getElementsByClassName("ai-analysis")
        );
        var detailsArr = Array.from(document.getElementsByClassName("details"));
        var detailsMapper = new Map();
        var analysisBoxCounter = 0;

        detailsArr.forEach((detailBtn) => {
          detailsMapper.set(detailBtn, analysisBoxArr[analysisBoxCounter]);
          analysisBoxCounter++;

          detailBtn.addEventListener("click", function () {
            let analysisBox = detailsMapper.get(detailBtn);
            if (!detailBtn.classList.contains("show")) {
              detailBtn.classList.add("show");
              analysisBox.style.height = "fit-content";
            } else {
              detailBtn.classList.remove("show");
              analysisBox.style.height = "125px";
            }
          });
        });

        //Comment section
        var commentsHolderArr = Array.from(
          document.getElementsByClassName("comments-holder")
        );
        var reviewsBtnArr = Array.from(
          document.getElementsByClassName("reviews")
        );
        var reviewsMapper = new Map();
        var commentsHolderCounter = 0;

        reviewsBtnArr.forEach((reviewBtn) => {
          reviewsMapper.set(
            reviewBtn,
            commentsHolderArr[commentsHolderCounter]
          );
          commentsHolderCounter++;

          reviewBtn.addEventListener("click", function () {
            let postComments = reviewsMapper.get(reviewBtn);
            postComments.style.display = "block";
          });
        });

        //Close buttons for comment modals
        var closeBtns = Array.from(
          document.getElementsByClassName("close-btn")
        );
        closeBtns.forEach((btn) => {
          btn.addEventListener("click", function () {
            let modalHolder = btn.parentElement.parentElement;
            modalHolder.style.display = "none";
          });
        });

        // sending a comment
        var inputArr = Array.from(document.getElementsByTagName("input"));
        var sendArr = Array.from(document.getElementsByClassName("send-btn"));
        var inputCounter = 0;
        var sendMapper = new Map();

        sendArr.forEach((sendBtn) => {
          sendMapper.set(sendBtn, inputArr[inputCounter]);
          inputCounter++;

          sendBtn.addEventListener("click", function () {
            let input = sendMapper.get(sendBtn);
            let review = input.value.trim();
            if (review.length > 1) {
              // fetch api
              let commenter = sessionStorage.getItem("user").split("@")[0];
              let postId = sendBtn.getAttribute("id");
              console.log({ postId, review, commenter });
              fetch("/comments", {
                method: "POST",
                headers: { "Content-Type": "application/json" },
                body: JSON.stringify({
                  review,
                  commenter,
                  postId,
                }),
              })
                .then((Response) => Response.json())
                .then((data) => {
                  if (data.message == "sent") {
                    alert("Comment sent, refresh page to view.");
                    input.value = "";
                  } else {
                    alert("Error! Comment not sent");
                  }
                });
            } else {
              alert("Please provide more content for the comment.");
            }
          });
        });

        // ==========================
        // Inline Posting JavaScript
        // ==========================
        var textarea = document.getElementById("content");
        var charCounter = document.getElementById("character-counter");
        if(textarea) {
          textarea.setAttribute("maxlength", "1000");
          textarea.addEventListener("input", function () {
            let counter = textarea.value.length;
            if (counter >= 1000) {
              charCounter.innerText = "Max";
            } else {
              charCounter.innerText = counter;
            }
          });
        }

        // Image Handling
        var imageUpload = document.getElementById("image-upload");
        var userMessage = document.getElementById("user-message");
        var imageLabel = document.getElementById("image-label");
        var holder = document.getElementById("holder");
        var imageFile = null;

        if(imageUpload) {
          imageUpload.addEventListener("change", function (e) {
            let files = e.target.files;
            if(files.length === 0) return;
            
            let file = files[0];
            imageFile = file;
            let size = file.size;
            if (size > 10000000) {
              userMessage.style.color = "red";
              userMessage.innerText = "File must be 10MBs max";
            } else {
              const reader = new FileReader();
              imageLabel.innerHTML = `<span class="text-xs text-primary">Image Selected</span>`;
              userMessage.innerText = "";
              
              reader.readAsDataURL(file);
              reader.onload = function (event) {
                holder.style.display = "block";
                holder.style.backgroundImage = `url(${event.target.result})`;
              };
            }
          });
        }

        // Post submission
        var postBtn = document.getElementById("post-btn");
        var errorMessage = document.getElementById("error-message");
        var sectorInput = document.getElementById("current-sector");

        if(postBtn) {
          postBtn.addEventListener("click", function (e) {
            e.preventDefault();
            if (textarea.value.trim() == "") {
              errorMessage.innerText = "Please provide some text for context.";
              setTimeout(function () {
                errorMessage.innerText = "";
              }, 5000);
              return;
            } else {
              let uploadData = new FormData();
              uploadData.append("image", imageFile);
              uploadData.append("content", textarea.value);
              
              // Only insert sector if one explicitly exists on the page
              if (sectorInput && sectorInput.value.trim() !== "") {
                uploadData.append("sector", sectorInput.value);
              }

              // Modal Management
              let modalHolder = document.getElementsByClassName("modal-overlay")[0];
              let modal = document.getElementById("waiting");
              modalHolder.style.display = "flex";
              let messageArr = [
                "Please wait while we process the content.",
                "AI analyzing content.",
              ];
              let messageCounter = 0;
              let modalInterval = setInterval(function () {
                modal.textContent = messageArr[messageCounter];
                messageCounter++;
                if (messageCounter > 1) {
                  messageCounter = 0;
                }
              }, 3000);

              fetch("/post", {
                method: "POST",
                body: uploadData,
              })
                .then((Response) => Response.json())
                .then((data) => {
                  clearInterval(modalInterval);
                  if (data.color == "red" || data.color == "orange") {
                    userMessage.textContent = data.message;
                    userMessage.style.color = "red";
                    modalHolder.style.display = "none";
                  } else {
                    modal.textContent = "Successfully uploaded content.";
                    window.location.reload(); // Refresh inline to show new post!
                  }
                });
            }
          });
        }
      };

      document.addEventListener("DOMContentLoaded", function() {
        // Hamburger Menu Toggle Logic
        var sectorsMenuBtn = document.getElementById("sectors-menu-btn");
        var sectorsDropdown = document.getElementById("sectors-dropdown");
        
        if (sectorsMenuBtn && sectorsDropdown) {
          sectorsMenuBtn.addEventListener("click", function (event) {
            event.preventDefault();
            event.stopPropagation(); // Prevent immediate closing
            sectorsDropdown.classList.toggle("hidden");
          });
          
          // Close dropdown when clicking outside
          window.addEventListener("click", function (e) {
            if (!sectorsMenuBtn.contains(e.target) && !sectorsDropdown.contains(e.target)) {
              sectorsDropdown.classList.add("hidden");
            }
          });
        }

        // Mobile Sectors Toggle
        var mobileSectorsBtn = document.getElementById("mobile-sectors-btn");
        var mobileSectorsMenu = document.getElementById("mobile-sectors-menu");
        if (mobileSectorsBtn && mobileSectorsMenu) {
          mobileSectorsBtn.addEventListener("click", function(e) {
            e.preventDefault();
            mobileSectorsMenu.classList.toggle("hidden");
          });
        }

        // Handle "Post" links scrolling to form
        document.querySelectorAll('a[href="/post"]').forEach(link => {
          link.addEventListener('click', function(e) {
            const form = document.querySelector('.inline-posting-form-container');
            if (form) {
              e.preventDefault();
              form.scrollIntoView({ behavior: 'smooth', block: 'center' });
              document.getElementById('content').focus();
            }
          });
        });
      });
    </script>
  </body>
</html>
