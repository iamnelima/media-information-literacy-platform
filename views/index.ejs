                      stroke="currentColor"
                      stroke-linecap="round"
                      stroke-linejoin="round"
                      stroke-width="2px"
                      d="M9.01486 3 9.01486 21"
                    ></path>
                    <path
                      fill="none"
                      stroke="currentColor"
                      stroke-linecap="round"
                      stroke-linejoin="round"
                      stroke-width="2px"
                      d="M14.98514 3 14.98514 21"
                    ></path>
                    <path
                      fill="none"
                      stroke="currentColor"
                      stroke-linecap="round"
                      stroke-linejoin="round"
                      stroke-width="2px"
                      d="M21 9.01486 3 9.01486"
                    ></path>
                    <path
                      fill="none"
                      stroke="currentColor"
                      stroke-linecap="round"
                      stroke-linejoin="round"
                      stroke-width="2px"
                      d="M21 14.98514 3 14.98514"
                    ></path></svg
                  ><span class="hidden lg:inline">My Posts</span></a
                >
              </div>
              <div class="flex items-center space-x-3">
                <span
                  class="relative flex shrink-0 overflow-hidden rounded-full w-8 h-8"
                  ><img
                    class="aspect-square h-full w-full"
                    src="/images/smiley.webp"
                /></span>
              </div>
            </div>
          </div>
          <div class="md:hidden border-t border-border">
            <div class="flex justify-around py-2">
              <a
                class="flex flex-col items-center space-y-1 px-3 py-2 rounded-lg text-primary"
                href="/"
                ><svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-house w-5 h-5"><path d="M15 21v-8a1 1 0 0 0-1-1h-4a1 1 0 0 0-1 1v8"></path><path d="M3 10a2 2 0 0 1 .709-1.528l7-5.999a2 2 0 0 1 2.582 0l7 5.999A2 2 0 0 1 21 10v9a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"></path></svg><span class="text-xs">Home</span></a
              ><a
                class="flex flex-col items-center space-y-1 px-3 py-2 rounded-lg text-muted-foreground"
                href="/post"
                ><svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-circle-plus w-5 h-5"><circle cx="12" cy="12" r="10"></circle><path d="M8 12h8"></path><path d="M12 8v8"></path></svg><span class="text-xs">Post</span></a
              ><a
                id="mobile-sectors-btn"
                class="flex flex-col items-center space-y-1 px-3 py-2 rounded-lg text-muted-foreground cursor-pointer"
                href="#"
                ><svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-menu w-5 h-5"><line x1="4" x2="20" y1="12" y2="12"/><line x1="4" x2="20" y1="6" y2="6"/><line x1="4" x2="20" y1="18" y2="18"/></svg><span class="text-xs">Sectors</span></a
              ><a
                class="flex flex-col items-center space-y-1 px-3 py-2 rounded-lg text-muted-foreground"
                href="/profile"
                ><svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-user w-5 h-5"><path d="M19 21v-2a4 4 0 0 0-4-4H9a4 4 0 0 0-4 4v2"></path><circle cx="12" cy="7" r="4"></circle></svg><span class="text-xs">Profile</span></a
              ><a
                class="flex flex-col items-center space-y-1 px-3 py-2 rounded-lg text-muted-foreground"
                href="/myposts"
                ><svg viewBox="0 0 24 24" width="24" height="24" fill="currentColor" class="x14rh7hd"><title>Posts</title><path fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2px" d="M3 3H21V21H3z"></path><path fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2px" d="M9.01486 3 9.01486 21"></path><path fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2px" d="M14.98514 3 14.98514 21"></path><path fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2px" d="M21 9.01486 3 9.01486"></path><path fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2px" d="M21 14.98514 3 14.98514"></path></svg><span class="text-xs">My Posts</span></a
              >
            </div>
          </div>
          <!-- Mobile Sectors Sliding Menu -->
          <div id="mobile-sectors-menu" class="md:hidden hidden bg-card border-t border-border">
            <div class="grid grid-cols-2 gap-2 p-4">
              <a href="/sectors/politics" class="flex items-center space-x-2 p-3 rounded-lg hover:bg-muted text-sm border border-border/50 justify-center">Politics</a>
              <a href="/sectors/health" class="flex items-center space-x-2 p-3 rounded-lg hover:bg-muted text-sm border border-border/50 justify-center">Health</a>
              <a href="/sectors/tech" class="flex items-center space-x-2 p-3 rounded-lg hover:bg-muted text-sm border border-border/50 justify-center">Tech</a>
              <a href="/sectors/business" class="flex items-center space-x-2 p-3 rounded-lg hover:bg-muted text-sm border border-border/50 justify-center">Business</a>
              <a href="/sectors/science" class="flex items-center space-x-2 p-3 rounded-lg hover:bg-muted text-sm border border-border/50 justify-center">Science</a>
              <a href="/sectors/entertainment" class="flex items-center space-x-2 p-3 rounded-lg hover:bg-muted text-sm border border-border/50 justify-center">Entertainment</a>
              <a href="/sectors/agriculture" class="flex items-center col-span-2 space-x-2 p-3 rounded-lg hover:bg-muted text-sm border border-border/50 justify-center">Agriculture</a>
