<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>MILES - Media &amp; Information Literacy Engagement System</title>
    <meta
      name="description"
      content="Fight misinformation with AI-powered credibility analysis and collaborative fact-checking"
    />
    <meta name="author" content="MILES Platform" />

    <meta
      property="og:title"
      content="MILES - Media &amp; Information Literacy Platform"
    />
    <meta
      property="og:description"
      content="Join a community dedicated to fighting misinformation through AI-powered credibility analysis"
    />
    <meta property="og:type" content="website" />
    <meta
      property="og:image"
      content="https://lovable.dev/opengraph-image-p98pqg.png"
    />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:site" content="@lovable_dev" />
    <meta
      name="twitter:image"
      content="https://lovable.dev/opengraph-image-p98pqg.png"
    />

    <link rel="stylesheet" crossorigin="" href="css/index.css" />

    <style>
      /* ── Strength bar ── */
      .strength-track {
        height: 5px;
        background: #e5e7eb;
        border-radius: 999px;
        overflow: hidden;
        margin-top: 6px;
        margin-bottom: 3px;
      }
      #strength-bar {
        height: 100%;
        width: 0%;
        border-radius: 999px;
        transition: width 0.3s ease, background 0.3s ease;
      }
      #strength-label {
        font-size: 0.72rem;
        font-weight: 600;
        letter-spacing: 0.03em;
      }

      /* ── Rule checklist ── */
      .password-rules {
        list-style: none;
        padding: 0;
        margin: 6px 0 0;
        display: flex;
        flex-direction: column;
        gap: 2px;
      }
      .password-rules li {
        font-size: 0.72rem;
        color: #9ca3af;
        display: flex;
        align-items: center;
        gap: 5px;
        transition: color 0.2s;
      }
      .password-rules li.rule-pass { color: #16a34a; }
      .password-rules li.rule-fail { color: #ef4444; }

      /* ── Field-level error ── */
      .field-error {
        font-size: 0.72rem;
        color: #ef4444;
        margin-top: 3px;
        min-height: 1em;
      }

      /* ── Input error highlight ── */
      .input-error {
        border-color: #ef4444 !important;
      }

      /* ── Match indicator ── */
      #password-match-msg {
        font-size: 0.72rem;
        margin-top: 3px;
        min-height: 1em;
      }
    </style>
  </head>
  <body>
    <div id="root">
      <div
        role="region"
        aria-label="Notifications (F8)"
        tabindex="-1"
        style="pointer-events: none"
      >
        <ol
          tabindex="-1"
          class="fixed top-0 z-[100] flex max-h-screen w-full flex-col-reverse p-4 sm:bottom-0 sm:right-0 sm:top-auto sm:flex-col md:max-w-[420px]"
        ></ol>
      </div>
      <section
        aria-label="Notifications alt+T"
        tabindex="-1"
        aria-live="polite"
        aria-relevant="additions text"
        aria-atomic="false"
      ></section>
      <div
        class="min-h-screen flex items-center justify-center p-4 relative"
        style="
          background-image: linear-gradient(
              rgba(248, 250, 252, 0.95),
              rgba(248, 250, 252, 0.95)
            ),
            url('/assets/hero-bg-BWptei3E.jpg');
          background-size: cover;
          background-position: center center;
          background-repeat: no-repeat;
        "
      >
        <div class="w-full max-w-6xl grid lg:grid-cols-2 gap-8 items-center">
          <div class="space-y-8">
            <div class="space-y-4">
              <div class="flex items-center space-x-3">
                <div
                  class="w-12 h-12 bg-gradient-to-br from-primary to-primary-glow rounded-xl flex items-center justify-center shadow-lg"
                >
                  <span class="text-primary-foreground font-bold text-xl">M</span>
                </div>
                <h1
                  class="text-3xl font-bold bg-gradient-to-r from-primary to-primary-glow bg-clip-text text-transparent"
                >
                  MILES
                </h1>
              </div>
              <p class="text-xl text-muted-foreground">
                Media &amp; Information Literacy Engagement System
              </p>
              <p class="text-foreground leading-relaxed">
                Join a community dedicated to fighting misinformation through
                AI-powered credibility analysis and collaborative fact-checking.
              </p>
            </div>
            <div class="grid sm:grid-cols-2 gap-4">
              <div class="flex items-start space-x-3 p-4 rounded-lg bg-card/50 border border-border/50">
                <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-shield w-6 h-6 text-credible-high mt-1 flex-shrink-0">
                  <path d="M20 13c0 5-3.5 7.5-7.66 8.95a1 1 0 0 1-.67-.01C7.5 20.5 4 18 4 13V6a1 1 0 0 1 1-1c2 0 4.5-1.2 6.24-2.72a1.17 1.17 0 0 1 1.52 0C14.51 3.81 17 5 19 5a1 1 0 0 1 1 1z"></path>
                </svg>
                <div>
                  <h3 class="font-semibold text-sm">AI Credibility Analysis</h3>
                  <p class="text-xs text-muted-foreground mt-1">Get instant reliability scores for posts and media</p>
                </div>
              </div>
              <div class="flex items-start space-x-3 p-4 rounded-lg bg-card/50 border border-border/50">
                <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-users w-6 h-6 text-primary mt-1 flex-shrink-0">
                  <path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"></path>
                  <circle cx="9" cy="7" r="4"></circle>
                  <path d="M22 21v-2a4 4 0 0 0-3-3.87"></path>
                  <path d="M16 3.13a4 4 0 0 1 0 7.75"></path>
                </svg>
                <div>
                  <h3 class="font-semibold text-sm">Community Reviews</h3>
                  <p class="text-xs text-muted-foreground mt-1">Collaborate with others to verify information</p>
                </div>
              </div>
              <div class="flex items-start space-x-3 p-4 rounded-lg bg-card/50 border border-border/50">
                <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-brain w-6 h-6 text-primary mt-1 flex-shrink-0">
                  <path d="M12 5a3 3 0 1 0-5.997.125 4 4 0 0 0-2.526 5.77 4 4 0 0 0 .556 6.588A4 4 0 1 0 12 18Z"></path>
                  <path d="M12 5a3 3 0 1 1 5.997.125 4 4 0 0 1 2.526 5.77 4 4 0 0 1-.556 6.588A4 4 0 1 1 12 18Z"></path>
                  <path d="M15 13a4.5 4.5 0 0 1-3-4 4.5 4.5 0 0 1-3 4"></path>
                  <path d="M17.599 6.5a3 3 0 0 0 .399-1.375"></path>
                  <path d="M6.003 5.125A3 3 0 0 0 6.401 6.5"></path>
                  <path d="M3.477 10.896a4 4 0 0 1 .585-.396"></path>
                  <path d="M19.938 10.5a4 4 0 0 1 .585.396"></path>
                  <path d="M6 18a4 4 0 0 1-1.967-.516"></path>
                  <path d="M19.967 17.484A4 4 0 0 1 18 18"></path>
                </svg>
                <div>
                  <h3 class="font-semibold text-sm">AI Tutor</h3>
                  <p class="text-xs text-muted-foreground mt-1">Learn media literacy with personalized guidance</p>
                </div>
              </div>
              <div class="flex items-start space-x-3 p-4 rounded-lg bg-card/50 border border-border/50">
                <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-eye w-6 h-6 text-primary mt-1 flex-shrink-0">
                  <path d="M2.062 12.348a1 1 0 0 1 0-.696 10.75 10.75 0 0 1 19.876 0 1 1 0 0 1 0 .696 10.75 10.75 0 0 1-19.876 0"></path>
                  <circle cx="12" cy="12" r="3"></circle>
                </svg>
                <div>
                  <h3 class="font-semibold text-sm">Critical Thinking</h3>
                  <p class="text-xs text-muted-foreground mt-1">Develop skills to identify reliable sources</p>
                </div>
              </div>
            </div>
          </div>

          <!-- ══ Auth Card ═════════════════════════════════════════════ -->
          <div class="w-full max-w-md mx-auto">
            <div class="rounded-lg text-card-foreground shadow-xl border-0 bg-card/95 backdrop-blur">
              <div class="flex flex-col space-y-1.5 p-6 text-center pb-4">
                <h3 class="font-semibold tracking-tight text-2xl">Welcome to MILES</h3>
                <p class="text-sm text-muted-foreground">Sign in to start analyzing media credibility</p>
                <p class="text-sm font-medium" id="user-message" style="min-height:1.2em; white-space:pre-line;"></p>
              </div>
              <div class="p-6 pt-0">
                <div dir="ltr" data-orientation="horizontal" class="w-full">
                  <!-- Tabs -->
                  <div
                    role="tablist"
                    class="h-10 items-center justify-center rounded-md bg-muted p-1 text-muted-foreground grid w-full grid-cols-2 mb-6"
                    tabindex="0"
                    data-orientation="horizontal"
                    style="outline: none"
                  >
                    <button
                      type="button"
                      role="tab"
                      class="sign-in-trigger clicked inline-flex items-center justify-center whitespace-nowrap rounded-sm px-3 py-1.5 text-sm font-medium ring-offset-background transition-all focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring focus-visible:ring-offset-2"
                      tabindex="0"
                    >Sign In</button>
                    <button
                      type="button"
                      role="tab"
                      class="sign-up-trigger inline-flex items-center justify-center whitespace-nowrap rounded-sm px-3 py-1.5 text-sm font-medium ring-offset-background transition-all focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring focus-visible:ring-offset-2"
                      tabindex="-1"
                    >Sign Up</button>
                  </div>

                  <!-- ── Sign In Form ── -->
                  <form class="sign-in-form space-y-4">
                    <div class="space-y-2">
                      <label class="text-sm font-medium leading-none" for="sign-in-email">Email</label>
                      <input
                        name="email"
                        type="email"
                        class="flex h-10 w-full rounded-md border border-input bg-background px-3 py-2 text-base ring-offset-background placeholder:text-muted-foreground focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring focus-visible:ring-offset-2 md:text-sm"
                        id="sign-in-email"
                        placeholder="your@email.com"
                        required
                      />
                      <p class="field-error" id="signin-email-error"></p>
                    </div>
                    <div class="space-y-2">
                      <label class="text-sm font-medium leading-none" for="sign-in-password">Password</label>
                      <input
                        name="password"
                        type="password"
                        class="flex h-10 w-full rounded-md border border-input bg-background px-3 py-2 text-base ring-offset-background placeholder:text-muted-foreground focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring focus-visible:ring-offset-2 md:text-sm"
                        id="sign-in-password"
                        placeholder="Enter Password"
                        required
                      />
                    </div>
                    <button
                      class="inline-flex items-center justify-center gap-2 whitespace-nowrap rounded-md text-sm font-medium bg-primary text-primary-foreground hover:bg-primary/90 h-10 px-4 py-2 w-full bg-gradient-to-r from-primary to-primary-glow hover:opacity-90 transition-opacity"
                      type="submit"
                      id="sign-in-btn"
                    >Sign In</button>
                  </form>

                  <!-- ── Sign Up Form ── -->
                  <form class="sign-up-form space-y-4" style="display: none">
                    <!-- Username -->
                    <div class="space-y-2">
                      <label class="text-sm font-medium leading-none" for="signup-username">Username</label>
                      <input
                        name="username"
                        type="text"
                        class="flex h-10 w-full rounded-md border border-input bg-background px-3 py-2 text-base ring-offset-background placeholder:text-muted-foreground focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring focus-visible:ring-offset-2 md:text-sm"
                        id="signup-username"
                        placeholder="Choose a username"
                        required
                      />
                    </div>

                    <!-- Email -->
                    <div class="space-y-2">
                      <label class="text-sm font-medium leading-none" for="signup-email">Email</label>
                      <input
                        name="email"
                        type="email"
                        class="flex h-10 w-full rounded-md border border-input bg-background px-3 py-2 text-base ring-offset-background placeholder:text-muted-foreground focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring focus-visible:ring-offset-2 md:text-sm"
                        id="signup-email"
                        placeholder="your@email.com"
                        required
                      />
                      <p class="field-error" id="signup-email-error"></p>
                    </div>

                    <!-- Password + strength meter -->
                    <div class="space-y-2">
                      <label class="text-sm font-medium leading-none" for="signup-password">Password</label>
                      <input
                        name="password"
                        type="password"
                        class="flex h-10 w-full rounded-md border border-input bg-background px-3 py-2 text-base ring-offset-background placeholder:text-muted-foreground focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring focus-visible:ring-offset-2 md:text-sm"
                        id="signup-password"
                        placeholder="Create a strong password"
                        required
                      />
                      <!-- Strength bar -->
                      <div class="strength-track"><div id="strength-bar"></div></div>
                      <span id="strength-label"></span>
                      <!-- Rule checklist -->
                      <ul class="password-rules">
                        <li id="rule-length"><span class="rule-icon">❌</span> At least 12 characters</li>
                        <li id="rule-upper"><span class="rule-icon">❌</span> One uppercase letter (A–Z)</li>
                        <li id="rule-lower"><span class="rule-icon">❌</span> One lowercase letter (a–z)</li>
                        <li id="rule-number"><span class="rule-icon">❌</span> One number (0–9)</li>
                        <li id="rule-special"><span class="rule-icon">❌</span> One special character (!@#$%^&amp;*)</li>
                      </ul>
                    </div>

                    <!-- Confirm password -->
                    <div class="space-y-2">
                      <label class="text-sm font-medium leading-none" for="confirm-password">Confirm Password</label>
                      <input
                        name="confirm-password"
                        type="password"
                        class="flex h-10 w-full rounded-md border border-input bg-background px-3 py-2 text-base ring-offset-background placeholder:text-muted-foreground focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring focus-visible:ring-offset-2 md:text-sm"
                        id="confirm-password"
                        placeholder="Confirm Password"
                        required
                      />
                      <p id="password-match-msg"></p>
                    </div>

                    <button
                      id="create-account"
                      class="inline-flex items-center justify-center gap-2 whitespace-nowrap rounded-md text-sm font-medium bg-primary text-primary-foreground hover:bg-primary/90 h-10 px-4 py-2 w-full bg-gradient-to-r from-primary to-primary-glow hover:opacity-90 transition-opacity"
                      type="submit"
                    >Create Account</button>
                  </form>

                </div>
              </div>
            </div>
          </div>
          <!-- ══ End Auth Card ══════════════════════════════════════════ -->

        </div>
      </div>
    </div>

    <script>
      // ─── Constants ────────────────────────────────────────────────────────────

      const DISPOSABLE_DOMAINS = new Set([
        "mailinator.com","tempmail.com","guerrillamail.com","10minutemail.com",
        "yopmail.com","trashmail.com","fakeinbox.com","maildrop.cc",
        "dispostable.com","spamgourmet.com","sharklasers.com","spam4.me",
        "trashmail.at","trashmail.io","trashmail.me","discard.email",
        "mailnull.com","tempr.email","getnada.com","bouncr.com",
        "filzmail.com","mailnesia.com","noblepioneer.com","throwam.com",
      ]);

      const EMAIL_REGEX = /^[a-zA-Z0-9.!#$%&'*+/=?^_`{|}~-]+@[a-zA-Z0-9](?:[a-zA-Z0-9-]{0,61}[a-zA-Z0-9])?(?:\.[a-zA-Z0-9](?:[a-zA-Z0-9-]{0,61}[a-zA-Z0-9])?)*\.[a-zA-Z]{2,}$/;

      const RULES = [
        { id: "rule-length",  regex: /.{12,}/,       label: "At least 12 characters"   },
        { id: "rule-upper",   regex: /[A-Z]/,         label: "One uppercase letter"      },
        { id: "rule-lower",   regex: /[a-z]/,         label: "One lowercase letter"      },
        { id: "rule-number",  regex: /[0-9]/,         label: "One number"                },
        { id: "rule-special", regex: /[^A-Za-z0-9]/,  label: "One special character"    },
      ];

      // ─── Helpers ──────────────────────────────────────────────────────────────

      function validateEmail(email) {
        const trimmed = email.trim().toLowerCase();
        if (!EMAIL_REGEX.test(trimmed)) return "Please enter a valid email address.";
        const domain = trimmed.split("@")[1];
        if (DISPOSABLE_DOMAINS.has(domain)) return "Disposable email addresses are not allowed.";
        return null;
      }

      function showMessage(text, color) {
        const el = document.getElementById("user-message");
        const map = { red:"#ef4444", green:"#22c55e", blue:"#3b82f6" };
        el.style.color = map[color] || color;
        el.textContent = text;
      }

      function setFieldError(id, msg) {
        const el = document.getElementById(id);
        if (el) el.textContent = msg || "";
      }

      function setInputError(inputEl, hasError) {
        if (!inputEl) return;
        inputEl.classList.toggle("input-error", hasError);
      }

      // ─── Strength Meter ───────────────────────────────────────────────────────

      function updateStrength(password) {
        const bar   = document.getElementById("strength-bar");
        const label = document.getElementById("strength-label");

        if (!password) {
          bar.style.width = "0%";
          label.textContent = "";
          RULES.forEach(({ id }) => {
            const li = document.getElementById(id);
            if (li) { li.classList.remove("rule-pass","rule-fail"); li.querySelector(".rule-icon").textContent = "❌"; }
          });
          return;
        }

        let passed = 0;
        RULES.forEach(({ id, regex }) => {
          const li   = document.getElementById(id);
          const icon = li ? li.querySelector(".rule-icon") : null;
          const ok   = regex.test(password);
          if (ok) passed++;
          if (li)  { li.classList.toggle("rule-pass", ok); li.classList.toggle("rule-fail", !ok); }
          if (icon) icon.textContent = ok ? "✅" : "❌";
        });

        const levels = [
          { pct:"20%", color:"#ef4444", text:"Very Weak"  },
          { pct:"40%", color:"#f97316", text:"Weak"       },
          { pct:"60%", color:"#eab308", text:"Fair"       },
          { pct:"80%", color:"#22c55e", text:"Strong"     },
          { pct:"100%",color:"#16a34a", text:"Very Strong"},
        ];
        const lvl = levels[passed - 1] || levels[0];
        bar.style.width      = lvl.pct;
        bar.style.background = lvl.color;
        label.textContent    = lvl.text;
        label.style.color    = lvl.color;
      }

      // ─── Wire Up ──────────────────────────────────────────────────────────────

      window.onload = function () {

        // Tab switching
        const signInTrigger = document.querySelector(".sign-in-trigger");
        const signUpTrigger = document.querySelector(".sign-up-trigger");
        const signInForm    = document.querySelector(".sign-in-form");
        const signUpForm    = document.querySelector(".sign-up-form");

        signInTrigger.addEventListener("click", function () {
          signInTrigger.classList.add("clicked");
          signUpTrigger.classList.remove("clicked");
          signInForm.style.display = "block";
          signUpForm.style.display = "none";
          showMessage("", "");
        });

        signUpTrigger.addEventListener("click", function () {
          signUpTrigger.classList.add("clicked");
          signInTrigger.classList.remove("clicked");
          signInForm.style.display = "none";
          signUpForm.style.display = "block";
          showMessage("", "");
        });

        // Live strength meter
        const signupPasswordInput = document.getElementById("signup-password");
        signupPasswordInput.addEventListener("input", function () {
          updateStrength(this.value);
        });

        // Live confirm-match indicator
        const confirmInput = document.getElementById("confirm-password");
        confirmInput.addEventListener("input", function () {
          const matchEl = document.getElementById("password-match-msg");
          if (!this.value) { matchEl.textContent = ""; return; }
          const match = this.value === signupPasswordInput.value;
          matchEl.textContent = match ? "✅ Passwords match" : "❌ Passwords do not match";
          matchEl.style.color = match ? "#16a34a" : "#ef4444";
          matchEl.style.fontSize = "0.72rem";
        });

        // Signup email blur validation
        const signupEmailInput = document.getElementById("signup-email");
        signupEmailInput.addEventListener("blur", function () {
          const err = validateEmail(this.value);
          setFieldError("signup-email-error", err || "");
          setInputError(this, !!err);
        });

        // Sign-in email blur validation
        const signinEmailInput = document.getElementById("sign-in-email");
        signinEmailInput.addEventListener("blur", function () {
          const err = validateEmail(this.value);
          setFieldError("signin-email-error", err || "");
          setInputError(this, !!err);
        });

        // ── Sign Up submit ────────────────────────────────────────────────────
        document.getElementById("create-account").addEventListener("click", function (e) {
          e.preventDefault();

          const email           = signupEmailInput.value.trim();
          const username        = document.getElementById("signup-username").value.trim();
          const password        = signupPasswordInput.value;
          const confirmPassword = confirmInput.value;

          // Empty check
          if (!username || !email || !password || !confirmPassword) {
            showMessage("All fields are required.", "red");
            return;
          }

          // Email validation
          const emailErr = validateEmail(email);
          if (emailErr) {
            setFieldError("signup-email-error", emailErr);
            setInputError(signupEmailInput, true);
            showMessage(emailErr, "red");
            return;
          }

          // Password rules
          const failedRules = RULES.filter((r) => !r.regex.test(password));
          if (failedRules.length > 0) {
            showMessage("Password requirements not met:\n• " + failedRules.map((r) => r.label).join("\n• "), "red");
            return;
          }

          // Passwords match
          if (password !== confirmPassword) {
            showMessage("Passwords do not match.", "red");
            return;
          }

          showMessage("Please wait while we create your account…", "blue");

          fetch("/signin", {
            method: "POST",
            headers: { "Content-Type": "application/json" },
            body: JSON.stringify({ email, password, confirmPassword, username }),
          })
            .then((r) => r.json())
            .then((data) => {
              showMessage(data.message, data.color);
              if (data.color === "green") {
                // Switch to sign-in tab after success
                setTimeout(() => {
                  signInTrigger.click();
                  showMessage("Account created! Please sign in.", "green");
                }, 1500);
              }
            })
            .catch(() => showMessage("Network error. Please try again.", "red"));
        });

        // ── Sign In submit ────────────────────────────────────────────────────
        document.getElementById("sign-in-btn").addEventListener("click", function (e) {
          e.preventDefault();

          const email    = signinEmailInput.value.trim();
          const password = document.getElementById("sign-in-password").value;

          if (!email || !password) {
            showMessage("Email and password are required.", "red");
            return;
          }

          const emailErr = validateEmail(email);
          if (emailErr) {
            setFieldError("signin-email-error", emailErr);
            setInputError(signinEmailInput, true);
            showMessage(emailErr, "red");
            return;
          }

          showMessage("Please wait. Logging in…", "blue");

          fetch("/login", {
            method: "POST",
            headers: { "Content-Type": "application/json" },
            body: JSON.stringify({ email, password }),
          })
            .then((r) => r.json())
            .then((data) => {
              showMessage(data.message, data.color);
              if (data.color === "green") {
                sessionStorage.setItem("user", data.user);
                sessionStorage.setItem("username", data.username);
                window.location.href = "/";
              }
            })
            .catch(() => showMessage("Network error. Please try again.", "red"));
        });
      };
    </script>
  </body>
</html>
