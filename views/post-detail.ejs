<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Post by <%= post.author %> | MILES</title>
    <script src="https://kit.fontawesome.com/f451cfc2d6.js" crossorigin="anonymous"></script>
    <link rel="stylesheet" href="/css/index.css" />
    <style>
      body { background: var(--background, #f8fafc); }
      .detail-wrap { max-width: 720px; margin: 0 auto; padding: 24px 16px 64px; }
      .back-btn {
        display: inline-flex; align-items: center; gap: 6px;
        font-size: 13px; font-weight: 500; color: #6b7280;
        padding: 6px 14px; border-radius: 999px;
        border: 1px solid #e5e7eb; background: white;
        cursor: pointer; text-decoration: none;
        transition: all 0.15s; margin-bottom: 20px;
      }
      .back-btn:hover { background: #f3f4f6; color: #111; }
      .post-card { background: white; border: 1px solid #e5e7eb; border-radius: 12px; padding: 28px; margin-bottom: 24px; }
      .author-chip { display: flex; align-items: center; gap: 10px; margin-bottom: 16px; }
      .author-avatar { width: 42px; height: 42px; border-radius: 50%; background: #ede9fe; color: #7c3aed; display: flex; align-items: center; justify-content: center; font-weight: 700; font-size: 16px; flex-shrink: 0; }
      .author-name { font-weight: 600; font-size: 15px; }
      .author-time { font-size: 12px; color: #9ca3af; }
      .post-image { width: 100%; border-radius: 8px; margin: 16px 0; max-height: 480px; object-fit: cover; }
      .post-text { font-size: 15px; line-height: 1.7; color: #1f2937; margin-bottom: 16px; }
      .badge { display: inline-flex; align-items: center; gap: 4px; font-size: 11px; font-weight: 600; padding: 3px 10px; border-radius: 999px; margin-right: 6px; margin-bottom: 6px; }
      .badge-sector { background: #f3f4f6; color: #374151; }
      .badge-claim { background: #fff3cd; color: #856404; border: 1px solid #ffc107; }
      .badge-ai { background: rgba(139,92,246,0.1); color: #7c3aed; border: 1px solid rgba(139,92,246,0.25); }
      .cred-section { background: #f9fafb; border: 1px solid #e5e7eb; border-radius: 10px; padding: 18px; margin-top: 20px; }
      .cred-label { font-size: 11px; font-weight: 600; text-transform: uppercase; letter-spacing: 0.05em; color: #9ca3af; margin-bottom: 10px; }
      .cred-score-row { display: flex; align-items: center; gap: 10px; margin-bottom: 8px; }
      .cred-score-num { font-size: 26px; font-weight: 800; }
      .verdict-pill { padding: 4px 12px; border-radius: 999px; font-size: 12px; font-weight: 700; color: white; }
      .cred-bar-bg { width: 100%; height: 8px; border-radius: 999px; background: #e5e7eb; overflow: hidden; margin-bottom: 6px; }
      .cred-bar-fill { height: 100%; border-radius: 999px; transition: width 0.6s ease; }
      .cred-breakdown { font-size: 11px; color: #9ca3af; }
      .analysis-text { font-size: 14px; color: #4b5563; line-height: 1.65; margin-top: 12px; }
      .verification-block { margin-top: 16px; }
      .v-section { margin-top: 14px; }
      .v-title { font-size: 11px; font-weight: 700; text-transform: uppercase; letter-spacing: 0.06em; color: #7c3aed; margin-bottom: 6px; }
      .v-claim { background: white; border: 1px solid #e5e7eb; border-radius: 8px; padding: 10px 12px; margin-bottom: 6px; font-size: 13px; }
      .v-claim strong { display: block; margin-bottom: 3px; color: #111; }
      .v-meta { font-size: 12px; color: #6b7280; }
      .v-item { font-size: 13px; color: #374151; padding: 5px 0; border-bottom: 1px solid #f3f4f6; }
      .v-item:last-child { border-bottom: none; }
      .source-chip { display: inline-flex; flex-direction: column; padding: 6px 10px; background: white; border: 1px solid #e5e7eb; border-radius: 8px; font-size: 11px; text-decoration: none; color: #374151; margin: 3px; transition: background 0.15s; }
      .source-chip:hover { background: #f3f4f6; }
      .source-chip small { color: #9ca3af; font-size: 10px; }
      .source-list { display: flex; flex-wrap: wrap; margin-top: 6px; }
      /* Comments */
      .comments-section { background: white; border: 1px solid #e5e7eb; border-radius: 12px; padding: 24px; }
      .comments-title { font-size: 16px; font-weight: 700; margin-bottom: 18px; display: flex; align-items: center; gap: 8px; }
      .comment-item { display: flex; gap: 10px; padding: 12px 0; border-bottom: 1px solid #f3f4f6; }
      .comment-item:last-child { border-bottom: none; }
      .comment-avatar { width: 34px; height: 34px; border-radius: 50%; background: #ede9fe; color: #7c3aed; display: flex; align-items: center; justify-content: center; font-weight: 700; font-size: 13px; flex-shrink: 0; }
      .comment-name { font-size: 13px; font-weight: 600; margin-bottom: 2px; }
      .comment-text { font-size: 13px; color: #374151; line-height: 1.5; }
      .comment-compose { display: flex; gap: 10px; margin-top: 20px; padding-top: 16px; border-top: 1px solid #e5e7eb; }
      .comment-compose input { flex: 1; padding: 10px 14px; border: 1px solid #d1d5db; border-radius: 8px; font-size: 14px; outline: none; }
      .comment-compose input:focus { border-color: #7c3aed; box-shadow: 0 0 0 3px rgba(124,58,237,0.12); }
      .comment-compose button { padding: 10px 18px; background: #7c3aed; color: white; border: none; border-radius: 8px; font-size: 14px; font-weight: 600; cursor: pointer; transition: background 0.15s; }
      .comment-compose button:hover { background: #6d28d9; }
      .no-comments { font-size: 14px; color: #9ca3af; text-align: center; padding: 20px 0; }
      nav.miles-nav { background: white; border-bottom: 1px solid #e5e7eb; padding: 0 16px; display: flex; align-items: center; justify-between: true; height: 56px; }
      .nav-inner { max-width: 720px; margin: 0 auto; display: flex; align-items: center; gap: 12px; height: 56px; }
      .nav-brand { font-size: 18px; font-weight: 800; background: linear-gradient(135deg,#7c3aed,#a855f7); -webkit-background-clip: text; -webkit-text-fill-color: transparent; text-decoration: none; }
    </style>
  </head>
  <body>
    <nav style="background:white;border-bottom:1px solid #e5e7eb;padding:0 16px;position:relative;">
      <div style="max-width:720px;margin:0 auto;display:flex;align-items:center;height:56px;gap:12px;">
        <a href="/" style="font-size:18px;font-weight:800;background:linear-gradient(135deg,#7c3aed,#a855f7);-webkit-background-clip:text;-webkit-text-fill-color:transparent;text-decoration:none;">MILES</a>
        <span style="flex:1;"></span>
        <a href="/post" style="font-size:13px;font-weight:500;padding:6px 14px;border-radius:8px;background:#7c3aed;color:white;text-decoration:none;">+ Post</a>
        <!-- Avatar dropdown -->
        <div style="position:relative;" id="nav-avatar-wrap">
          <button id="nav-avatar-btn" onclick="(function(){document.getElementById('nav-avatar-dropdown').classList.toggle('hidden');event.stopPropagation();})()" style="background:none;border:2px solid rgba(124,58,237,0.3);padding:0;cursor:pointer;border-radius:50%;width:34px;height:34px;overflow:hidden;display:flex;align-items:center;justify-content:center;">
            <img id="nav-avatar-img" src="/images/smiley.webp" alt="Profile" style="width:100%;height:100%;object-fit:cover;" />
          </button>
          <div id="nav-avatar-dropdown" class="hidden" style="position:absolute;right:0;top:calc(100% + 8px);width:175px;background:white;border:1px solid #e5e7eb;border-radius:10px;box-shadow:0 8px 24px rgba(0,0,0,0.10);z-index:999;overflow:hidden;">
            <div style="padding:12px 14px;border-bottom:1px solid #f3f4f6;">
              <p style="font-size:11px;color:#9ca3af;margin:0;">Signed in as</p>
              <p id="nav-user-email" style="font-size:12px;font-weight:600;color:#111;margin:2px 0 0;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;"></p>
            </div>
            <a href="/profile" style="display:flex;align-items:center;gap:8px;padding:10px 14px;font-size:13px;color:#374151;text-decoration:none;" onmouseover="this.style.background='#f9fafb'" onmouseout="this.style.background='none'">
              <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M19 21v-2a4 4 0 0 0-4-4H9a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
              View Profile
            </a>
            <button onclick="milesLogout()" style="display:flex;width:100%;align-items:center;gap:8px;padding:10px 14px;font-size:13px;color:#ef4444;background:none;border:none;border-top:1px solid #f3f4f6;cursor:pointer;" onmouseover="this.style.background='#fff5f5'" onmouseout="this.style.background='none'">
              <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"/><polyline points="16 17 21 12 16 7"/><line x1="21" x2="9" y1="12" y2="12"/></svg>
              Log Out
            </button>
          </div>
        </div>
      </div>
    </nav>

    <div class="detail-wrap">
      <a class="back-btn" onclick="history.back(); return false;" href="/">
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24"><path d="M19 12H5"/><path d="m12 5-7 7 7 7"/></svg>
        Back
      </a>

      <!-- Post Card -->
      <div class="post-card">
        <div class="author-chip">
          <div class="author-avatar"><%= post.author[0].toUpperCase() %></div>
          <div>
            <div class="author-name"><%= post.author %></div>
            <% if(post.created_at) { %>
              <div class="author-time"><%= new Date(post.created_at).toLocaleDateString('en-US',{year:'numeric',month:'long',day:'numeric',hour:'2-digit',minute:'2-digit'}) %></div>
            <% } %>
          </div>
        </div>

        <% if(post.image_location) { %>
          <img class="post-image" src="/<%= post.image_location %>" alt="Post image" loading="lazy" />
        <% } %>

        <p class="post-text"><%= post.text_content %></p>

        <!-- Badges row -->
        <div style="margin-bottom:8px;">
          <% if(post.sector) { %><a href="/sectors/<%= String(post.sector).toLowerCase() %>" class="badge badge-sector" style="text-decoration:none;">📌 <%= post.sector %></a><% } %>
          <% if(post.claim_count && post.claim_count > 1) { %><span class="badge badge-claim">📢 Seen <%= post.claim_count %> times</span><% } %>
          <% if(post.is_ai_generated) { %><span class="badge badge-ai">🤖 AI-Generated Content</span><% } %>
        </div>

        <!-- Credibility Section -->
        <div class="cred-section">
          <div class="cred-label">AI Credibility Analysis</div>
          <div class="cred-score-row">
            <span class="cred-score-num" style="color:<%= post.verdict_color||'#6b7280' %>;"><%= post.credibility_score %>%</span>
            <span class="verdict-pill" style="background:<%= post.verdict_color||'#6b7280' %>;"><%= post.verdict_label %></span>
          </div>
          <div class="cred-bar-bg">
            <div class="cred-bar-fill" style="width:<%= post.credibility_score %>%;background:<%= post.verdict_color||'#6b7280' %>;"></div>
          </div>
          <div class="cred-breakdown">
            <% if(post.verification && post.verification.score_breakdown) { %>
              <%= post.verification.score_breakdown %>
            <% } else { %>
              <% var unverified = 100 - (post.credibility_score || 0); %>
              <% if(unverified > 0) { %><%= unverified %>% of claims are weak or unverified<% } else { %>Fully supported by evidence<% } %>
            <% } %>
          </div>
          <p class="analysis-text"><%= post.ai_analysis %></p>

          <% if(post.verification) { %>
            <div class="verification-block">
              <% if(post.verification.verification_methodology) { %>
                <div class="v-section">
                  <div class="v-title">Methodology</div>
                  <p class="v-item"><%= post.verification.verification_methodology %></p>
                </div>
              <% } %>
              <% if(post.verification.key_claims && post.verification.key_claims.length > 0) { %>
                <div class="v-section">
                  <div class="v-title">Key Claims</div>
                  <% post.verification.key_claims.forEach((claim) => { %>
                    <div class="v-claim">
                      <strong><%= claim.claim %></strong>
                      <span class="v-meta"><strong><%= claim.assessment %></strong><% if(claim.confidence) { %> · <%= claim.confidence %> confidence<% } %></span>
                      <% if(claim.rationale) { %><p class="v-meta" style="margin-top:4px;"><%= claim.rationale %></p><% } %>
                    </div>
                  <% }); %>
                </div>
              <% } %>
              <% if(post.verification.supporting_evidence && post.verification.supporting_evidence.length > 0) { %>
                <div class="v-section">
                  <div class="v-title">Supporting Evidence</div>
                  <% post.verification.supporting_evidence.forEach((item) => { %>
                    <p class="v-item">✅ <%= item %></p>
                  <% }); %>
                </div>
              <% } %>
              <% if(post.verification.contradicting_evidence && post.verification.contradicting_evidence.length > 0) { %>
                <div class="v-section">
                  <div class="v-title">Contradicting Evidence</div>
                  <% post.verification.contradicting_evidence.forEach((item) => { %>
                    <p class="v-item">❌ <%= item %></p>
                  <% }); %>
                </div>
              <% } %>
              <% if(post.verification.recommended_checks && post.verification.recommended_checks.length > 0) { %>
                <div class="v-section">
                  <div class="v-title">Recommended Checks</div>
                  <% post.verification.recommended_checks.forEach((item) => { %>
                    <p class="v-item">🔍 <%= item %></p>
                  <% }); %>
                </div>
              <% } %>
              <% if(post.verification.sources && post.verification.sources.length > 0) { %>
                <div class="v-section">
                  <div class="v-title">Sources</div>
                  <div class="source-list">
                    <% post.verification.sources.forEach((source) => { %>
                      <a class="source-chip" href="<%= source.url %>" target="_blank" rel="noreferrer">
                        <span><%= source.title %></span>
                        <% if(source.domain) { %><small><%= source.domain %></small><% } %>
                      </a>
                    <% }); %>
                  </div>
                </div>
              <% } %>
            </div>
          <% } %>
        </div>
      </div>

      <!-- Comments Section -->
      <div class="comments-section">
        <div class="comments-title">
          <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M7.9 20A9 9 0 1 0 4 16.1L2 22Z"/></svg>
          Community Reviews
          <span id="comment-count" style="font-size:13px;font-weight:500;color:#9ca3af;">(<%= post.comments.length %>)</span>
        </div>

        <div id="comments-list">
          <% if(post.comments.length > 0) { %>
            <% post.comments.forEach((comment) => { %>
              <div class="comment-item">
                <div class="comment-avatar"><%= comment.commenter[0].toUpperCase() %></div>
                <div>
                  <div class="comment-name"><%= comment.commenter %></div>
                  <div class="comment-text"><%= comment.review %></div>
                </div>
              </div>
            <% }); %>
          <% } else { %>
            <p class="no-comments" id="no-comments-msg">No reviews yet — be the first to comment.</p>
          <% } %>
        </div>

        <div class="comment-compose">
          <input type="text" id="comment-input" placeholder="Add your review or observation..." maxlength="500" />
          <button id="send-comment-btn">Send</button>
        </div>
        <p id="comment-msg" style="font-size:12px;color:#ef4444;margin-top:6px;display:none;"></p>
      </div>
    </div>

    <script>
      const POST_ID = "<%= post.post_id %>";

      document.getElementById("send-comment-btn").addEventListener("click", function() {
        const input = document.getElementById("comment-input");
        const msgEl = document.getElementById("comment-msg");
        const review = input.value.trim();
        if (!review) return;

        const rawUser = sessionStorage.getItem("user") || "";
        const commenter = rawUser ? rawUser.split("@")[0] : "Anonymous";

        this.disabled = true;
        this.textContent = "Sending…";

        fetch("/comments", {
          method: "POST",
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify({ review, commenter, postId: POST_ID })
        })
        .then(r => r.json())
        .then(data => {
          if (data.message === "sent") {
            // Add comment to UI
            const list = document.getElementById("comments-list");
            const noMsg = document.getElementById("no-comments-msg");
            if (noMsg) noMsg.remove();

            const div = document.createElement("div");
            div.className = "comment-item";
            const safeReview = review.replace(/</g,"&lt;").replace(/>/g,"&gt;");
            div.innerHTML = `
              <div class="comment-avatar">${commenter[0].toUpperCase()}</div>
              <div>
                <div class="comment-name">${commenter}</div>
                <div class="comment-text">${safeReview}</div>
              </div>`;
            list.appendChild(div);

            // Update count
            const countEl = document.getElementById("comment-count");
            const current = parseInt(countEl.textContent.replace(/\D/g,"")) || 0;
            countEl.textContent = `(${current + 1})`;

            input.value = "";
            msgEl.style.display = "none";
          } else {
            msgEl.textContent = "Failed to send — please try again.";
            msgEl.style.display = "block";
          }
        })
        .catch(() => {
          msgEl.textContent = "Network error — please try again.";
          msgEl.style.display = "block";
        })
        .finally(() => {
          document.getElementById("send-comment-btn").disabled = false;
          document.getElementById("send-comment-btn").textContent = "Send";
        });
      });

      // Allow Enter key to submit
      document.getElementById("comment-input").addEventListener("keydown", function(e) {
        if (e.key === "Enter") document.getElementById("send-comment-btn").click();
      });

      // Avatar dropdown: close on outside click
      document.addEventListener('click', function(e) {
        var dd  = document.getElementById('nav-avatar-dropdown');
        var btn = document.getElementById('nav-avatar-btn');
        if (dd && btn && !btn.contains(e.target) && !dd.contains(e.target)) {
          dd.classList.add('hidden');
        }
      });

      // Load avatar + email from session
      (function() {
        var email = sessionStorage.getItem('user') || '';
        var emailEl = document.getElementById('nav-user-email');
        if (emailEl && email) emailEl.textContent = email;
        var savedPic = sessionStorage.getItem('profile_picture');
        var avatarImg = document.getElementById('nav-avatar-img');
        if (avatarImg && savedPic) avatarImg.src = '/' + savedPic;
      })();

      // Logout function
      function milesLogout() {
        var sure = confirm('Are you sure you want to log out?');
        if (sure) {
          sessionStorage.clear();
          fetch('/profile', { method: 'POST' }).then(function() {
            window.location.href = '/signin';
          });
        }
      }
    </script>
  </body>
</html>
