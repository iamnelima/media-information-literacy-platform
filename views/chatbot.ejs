    <script>
      window.onload = function () {
        var chat = document.getElementById("chat");

        var userPromptTemplate =
          document.getElementsByClassName("user-prompt")[0];
        var aiReplyTemplate =
          document.getElementsByClassName("ai-reply-template")[0];

        var inputField = document.getElementsByTagName("input")[0];
        var sendBtn = document.getElementById("send-btn");
        const ws = new WebSocket("ws://localhost:5001");

        var idempotentKey = crypto.randomUUID();
        console.log(idempotentKey);
        var user = sessionStorage.getItem("user");
        sessionStorage.setItem("key", idempotentKey);

        // Use session to store conversation

        sendBtn.addEventListener("click", function () {
          sendBtn.setAttribute("disabled", "");
          let userPrompt = inputField.value.trim();

          if (userPrompt.length > 0) {
            //Create socket

            inputField.value = "";
            var userChat = userPromptTemplate.cloneNode(true);
            userChat.style.display = "flex";
            chat.appendChild(userChat);
            var promptContentArr = Array.from(
              document.getElementsByClassName("prompt-content")
            );
            var promptContent = promptContentArr[promptContentArr.length - 1];
            promptContent.textContent = userPrompt;

            var aiReply = aiReplyTemplate.cloneNode(true);
            chat.appendChild(aiReply);
            let aiContentArr = Array.from(
              document.getElementsByClassName("ai-reply")
            );
            let aiContent = aiContentArr[aiContentArr.length - 1];
            aiContent.textContent = "Please wait for reply...";

            // set conversion from session
            let conversation = sessionStorage.getItem("conversation");
            conversation = conversation + "\n" + "USER: " + userPrompt + "\n";
            sessionStorage.setItem("conversation", conversation);

            ws.onopen = function () {
              console.log("Web Socket connection established sucessfully");
            };
            ws.onmessage = function (e) {
              //Add response to conversation in session
              conversation = conversation + "\n" + "MILES: " + e.data + "\n";
              sessionStorage.setItem("conversation", conversation);

              let text = e.data;
              let textArr = text.split("**");
              let newHTML = textArr[0];
              for (let i = 1; i < textArr.length; i = i + 2) {
                newHTML =
                  newHTML +
                  "<strong>" +
                  textArr[i] +
                  "</strong>" +
                  textArr[i + 1];
              }

              aiContent.innerHTML = newHTML;

              sendBtn.removeAttribute("disabled");
            };
            ws.onerror = function (e) {
              console.error("Error occured:\n" + e.message);
            };
            ws.onclose = function (e) {
              if (e.wasClean) {
                console.log(
                  "Connection was closed cleanly.\n Code: " +
                    e.code +
                    "\nReason: " +
                    e.reason
                );
              } else {
                console.log("Error occured! Connection Died!");
              }
            };

            if (ws.readyState == WebSocket.OPEN) {
              let promptToSend = sessionStorage.getItem("conversation");
              let key = sessionStorage.getItem("key");
              console.log(user);
              ws.send(JSON.stringify({ key, user, promptToSend }));
            } else {
              console.error("Error! Web Scoket not open! ");
            }
          } else {
            alert("Please provide prompt for Miles");
          }
        });

        //Quick Topics
        var topics = Array.from(
          document.getElementsByClassName("quick-topics")[0].children
        );
        topics.forEach((topic) => {
          topic.addEventListener("click", function () {
            inputField.value = topic.textContent.trim();
          });
        });
      };

      // ── Avatar dropdown: close on outside click ───────────────
      document.addEventListener('click', function(e) {
        var dd  = document.getElementById('nav-avatar-dropdown');
        var btn = document.getElementById('nav-avatar-btn');
        if (dd && btn && !btn.contains(e.target) && !dd.contains(e.target)) {
          dd.classList.add('hidden');
        }
      });

      // ── Load avatar + email from session ─────────────────────
      (function() {
        var email = sessionStorage.getItem('user') || '';
        var emailEl = document.getElementById('nav-user-email');
        if (emailEl && email) emailEl.textContent = email;
        var savedPic = sessionStorage.getItem('profile_picture');
        var avatarImg = document.getElementById('nav-avatar-img');
        if (avatarImg && savedPic) avatarImg.src = '/' + savedPic;
      })();

      // ── Logout function ──────────────────────────────────────
      function milesLogout() {
        var sure = confirm('Are you sure you want to log out?');
        if (sure) {
          sessionStorage.clear();
          fetch('/profile', { method: 'POST' }).then(function() {
            window.location.href = '/signin';
          });
        }
      }
    </script>
