        <main class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
          <div class="space-y-6">
            <div class="text-center space-y-2">
              <h1 class="text-2xl font-bold">My Posts</h1>
              <p class="text-muted-foreground">
                My Analysis of content credibility and engagement with verified
                information.
              </p>
            </div>
            <div class="max-w-2xl mx-auto">
              <% posts.forEach((post)=>{ %>
              <div
                id="<%=post.post_id%>"
                class="post rounded-lg border bg-card text-card-foreground mb-6 shadow-sm hover:shadow-md transition-shadow duration-200 border-border/50"
              >
                <div class="flex flex-col space-y-1.5 p-6 pb-3">
                  <div class="flex items-start justify-between">
                    <div class="flex items-center space-x-3">
                      <span
                        class="relative flex shrink-0 overflow-hidden rounded-full w-10 h-10"
                        ><span
                          class="flex h-full w-full items-center justify-center rounded-full bg-primary/10 text-primary"
                        >
                          <%= post.author[0] %></span
                        ></span
                      >
                      <div>
                        <h3 class="font-semibold text-sm">
                          <%= post.author %>
                        </h3>
                      </div>
                    </div>
                  </div>
                </div>

                <div class="p-6 pt-0 space-y-4">
                  <div class="space-y-3">
                    <%if(post.image_location){%>
                    <div
                      class="aspect-product overflow-hidden rounded-t-xl bg-muted/30"
                    >
                      <img
                        src="<%=post.image_location%>"
                        alt="Wimask Accesories Phones"
                        loading="lazy"
                        style="border-radius: 5px"
                        class="product-image h-full w-full object-cover transition-transform duration-300 group-hover:scale-105"
                        sizes="(max-width: 768px) 100vw, (max-width: 1200px) 50vw, 33vw"
                      />
                    </div>
                    <%}%>

                    <p class="text-foreground leading-relaxed">
                      <%=post.text_content%>
                    </p>
                  </div>
                  <hr />
                  <div class="bg-muted/30 rounded-lg p-4 space-y-3 ai-analysis">
                    <div class="flex items-center justify-between">
                      <div class="flex items-center space-x-3">
                        <div class="flex items-center space-x-2">
                          <span class="text-sm font-medium"
                            ><%=post.credibility_score%>%</span
                          >
                        </div>
                        <div
                          class="inline-flex items-center rounded-full border px-2.5 py-0.5 text-xs transition-colors focus:outline-none focus:ring-2 focus:ring-ring focus:ring-offset-2 border-transparent hover:bg-primary/80 bg-credible-high text-white font-medium"
                          style="background: <%=post.verdict_color%>"
                        >
                          <%= post.verdict_label %>
                        </div>
                      </div>
                      <button
                        class="details inline-flex items-center justify-center gap-2 whitespace-nowrap font-medium ring-offset-background transition-colors focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring focus-visible:ring-offset-2 disabled:pointer-events-none disabled:opacity-50 [&amp;_svg]:pointer-events-none [&amp;_svg]:size-4 [&amp;_svg]:shrink-0 hover:bg-accent hover:text-accent-foreground h-9 rounded-md px-3 text-xs"
                      >
                        Details
                        <svg
                          xmlns="http://www.w3.org/2000/svg"
                          width="24"
                          height="24"
                          viewBox="0 0 24 24"
                          fill="none"
                          stroke="currentColor"
                          stroke-width="2"
                          stroke-linecap="round"
                          stroke-linejoin="round"
                          class="lucide lucide-chevron-down w-3 h-3 ml-1"
                        >
                          <path d="m6 9 6 6 6-6"></path>
                        </svg>
                      </button>
                    </div>
                    <p class="text-sm text-muted-foreground">
                      <span class="font-medium text-foreground"
                        >AI Analysis:</span
                      >
                      <%=post.ai_analysis%>
                    </p>
                    <% if (post.verification) { %>
                    <div class="verification-block">
                      <% if (post.verification.verification_methodology) { %>
                      <p class="verification-meta">
                        <span class="font-medium text-foreground">Method:</span>
                        <%= post.verification.verification_methodology %>
                      </p>
                      <% } %>
                      <% if (post.verification.key_claims && post.verification.key_claims.length > 0) { %>
                      <div class="verification-section">
                        <p class="verification-title">Key Claims</p>
                        <% post.verification.key_claims.forEach((claim) => { %>
                        <div class="verification-item">
                          <p class="verification-claim"><%= claim.claim %></p>
                          <p class="verification-meta">
                            <strong><%= claim.assessment %></strong>
                            <% if (claim.confidence) { %>
                            | <%= claim.confidence %> confidence
                            <% } %>
                          </p>
                          <% if (claim.rationale) { %>
                          <p class="verification-meta"><%= claim.rationale %></p>
                          <% } %>
                        </div>
                        <% }) %>
                      </div>
                      <% } %>
                      <% if (post.verification.supporting_evidence && post.verification.supporting_evidence.length > 0) { %>
                      <div class="verification-section">
                        <p class="verification-title">Supporting Evidence</p>
                        <% post.verification.supporting_evidence.forEach((item) => { %>
                        <p class="verification-item"><%= item %></p>
                        <% }) %>
                      </div>
                      <% } %>
                      <% if (post.verification.contradicting_evidence && post.verification.contradicting_evidence.length > 0) { %>
                      <div class="verification-section">
                        <p class="verification-title">Contradicting Evidence</p>
                        <% post.verification.contradicting_evidence.forEach((item) => { %>
                        <p class="verification-item"><%= item %></p>
                        <% }) %>
                      </div>
                      <% } %>
                      <% if (post.verification.sources && post.verification.sources.length > 0) { %>
                      <div class="verification-section">
                        <p class="verification-title">Evidence Sources</p>
                        <div class="source-list">
                          <% post.verification.sources.forEach((source) => { %>
                          <a
                            class="source-chip"
                            href="<%= source.url %>"
                            target="_blank"
                            rel="noreferrer"
                          >
                            <span><%= source.title %></span>
                            <% if (source.domain) { %>
                            <small><%= source.domain %></small>
                            <% } %>
                          </a>
                          <% }) %>
                        </div>
                      </div>
                      <% } %>
                      <% if (post.verification.recommended_checks && post.verification.recommended_checks.length > 0) { %>
                      <div class="verification-section">
                        <p class="verification-title">Next Checks</p>
                        <% post.verification.recommended_checks.forEach((item) => { %>
                        <p class="verification-item"><%= item %></p>
                        <% }) %>
                      </div>
                      <% } %>
                    </div>
                    <% } %>
                  </div>
                  <div class="flex items-center justify-between pt-2">
                    <div class="flex items-center space-x-6">
                      <button
                        class="delete justify-center gap-2 whitespace-nowrap text-sm font-medium ring-offset-background transition-colors focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring focus-visible:ring-offset-2 disabled:pointer-events-none disabled:opacity-50 [&amp;_svg]:pointer-events-none [&amp;_svg]:size-4 [&amp;_svg]:shrink-0 hover:bg-accent h-9 rounded-md px-3 flex items-center space-x-2 text-muted-foreground hover:text-primary"
                      >
                        <i class="fa-solid fa-trash"></i>
                      </button>
                    </div>
                  </div>
                </div>
              </div>
              <%}) %>
            </div>
          </div>
        </main>
      </div>
    </div>
    <script>
      window.onload = function () {
        var postsArr = Array.from(document.getElementsByClassName("post"));
        var deleteArr = Array.from(document.getElementsByClassName("delete"));
        var postCounter = 0;
        var deleteMapper = new Map();
        deleteArr.forEach(function (deleteBtn) {
          deleteMapper.set(deleteBtn, postsArr[postCounter]);
          postCounter++;

          deleteBtn.addEventListener("click", function () {
            var id = deleteMapper.get(deleteBtn).getAttribute("id");
            fetch("/posts", {
              method: "DELETE",
              headers: { "Content-Type": "application/json" },
              body: JSON.stringify({ id }),
            })
              .then((Response) => Response.json())
              .then((data) => {
                if (data.message == "Deleted") {
                  window.location.href = "/myposts";
                }
              });
          });
        });

        //Details dropdown
        var analysisBoxArr = Array.from(
          document.getElementsByClassName("ai-analysis")
        );
        var detailsArr = Array.from(document.getElementsByClassName("details"));
        var detailsMapper = new Map();
        var analysisBoxCounter = 0;

        detailsArr.forEach((detailBtn) => {
          detailsMapper.set(detailBtn, analysisBoxArr[analysisBoxCounter]);
          analysisBoxCounter++;

          detailBtn.addEventListener("click", function () {
            let analysisBox = detailsMapper.get(detailBtn);
            if (!detailBtn.classList.contains("show")) {
              detailBtn.classList.add("show");
              analysisBox.style.height = "fit-content";
            } else {
              detailBtn.classList.remove("show");
              analysisBox.style.height = "125px";
            }
          });
        });
      };
    </script>
  </body>
</html>
